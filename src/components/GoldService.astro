---
// Gold Service — premium-tier callout rendered as a literal dark box
// sitting on the page's cream surface. Used on /home and the service
// pages. Paragraph-by-paragraph fade-in on scroll; the gold "Gold
// Service" wordmark inside <em> tags is left untouched so it stays
// visible the whole time while cream prose fills in around it.
---

<section class="black-box" aria-labelledby="gold-service-title">
  <div class="container-narrow black-box-inner">
    <h2 id="gold-service-title" class="display black-box-title">
      <em>Gold Service Mediation</em>
    </h2>

    <div class="black-box-body">
      <p>
        Certain matters require an elevated level of discretion,
        privacy, and professional oversight. Pro Se Fair Play Mediation
        offers <em>Gold Service Mediation</em>, designed for high-profile
        individuals, executives, athletes, entertainers, business
        owners, and parties involved in sensitive or high-conflict
        disputes.
      </p>

      <p>
        This service is tailored for clients who value
        confidentiality, reputation management, scheduling flexibility,
        and a secure, professionally managed mediation environment.
      </p>

      <p>
        <em>Gold Service Mediation</em> may include private virtual or in-person
        sessions, controlled communication protocols, flexible evening
        and weekend scheduling, customized session structures, and
        enhanced confidentiality measures throughout the process.
      </p>

      <p class="black-box-note">
        Pricing for <em>Gold Service Mediation</em> varies based on the nature
        and complexity of the matter. Please inquire during booking for
        additional information.
      </p>
    </div>
  </div>

  <script is:inline>
    (function () {
      function init() {
        const boxes = document.querySelectorAll(".black-box-inner");
        boxes.forEach(function (box) {
          if (box.dataset.bbInit === "1") return;
          box.dataset.bbInit = "1";

          // For each paragraph, collect its current text nodes first,
          // then replace each text node in place with a fragment of
          // word spans + whitespace nodes. <em> children are untouched.
          const body = box.querySelector(".black-box-body");
          const children = Array.prototype.slice.call(body.children);
          var paraIdx = 0;
          children.forEach(function (block, i) {
            var next = children[i + 1];
            var hosts = block.tagName === "UL"
              ? block.querySelectorAll("li")
              : [block];
            hosts.forEach(function (host) {
              var textNodes = [];
              for (var j = 0; j < host.childNodes.length; j++) {
                var n = host.childNodes[j];
                if (n.nodeType === 3) textNodes.push(n);
              }
              textNodes.forEach(function (tn) {
                var text = tn.nodeValue;
                if (text === "") return;
                var span = document.createElement("span");
                span.className = "bb-word";
                span.style.setProperty("--i", paraIdx);
                span.textContent = text;
                tn.parentNode.replaceChild(span, tn);
              });
            });
            var sharesWithNext = block.tagName === "P" && next && next.tagName === "UL";
            if (!sharesWithNext) paraIdx++;
          });

          // Trigger when the top of the box has scrolled into roughly
          // the top 40% of the viewport. Anchored to viewport so
          // mobile portrait (where the box is taller than the screen)
          // still triggers.
          var obs = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  box.classList.add("is-revealing");
                  obs.unobserve(box);
                }
              });
            },
            { threshold: 0, rootMargin: "0px 0px -40% 0px" }
          );
          obs.observe(box);
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
  </script>
</section>

<style>
  .black-box {
    position: relative;
    padding-block: var(--space-xl);
    padding-inline: clamp(1.25rem, 4vw, 3rem);
    background: var(--color-cream);
    isolation: isolate;
  }
  .black-box-inner {
    max-width: 40rem;
    margin-inline: auto;
    background:
      radial-gradient(ellipse 110% 90% at 50% 45%, transparent 30%, rgba(0, 0, 0, 0.55) 100%),
      #0b0c12;
    color: var(--color-cream);
    padding: clamp(2rem, 3vw + 1rem, 3rem) clamp(1.75rem, 3vw + 0.75rem, 2.5rem);
    border: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    border-radius: 3px;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.3),
      0 1px 0 color-mix(in srgb, var(--color-gold) 12%, transparent) inset,
      0 40px 80px -28px rgba(0, 0, 0, 0.55),
      0 0 80px -20px rgba(0, 0, 0, 0.4);
    position: relative;
  }
  .black-box-inner::before {
    content: "";
    position: absolute;
    top: 0; left: 12%; right: 12%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0.4;
  }
  .black-box-inner::after {
    content: "";
    position: absolute;
    bottom: 0; left: 12%; right: 12%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0.25;
  }
  .black-box-title {
    font-size: var(--step-3);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-cream);
    margin-bottom: 1.25rem;
    font-weight: 400;
  }
  .black-box-body {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-cream) 78%, transparent);
  }
  .black-box-body p + p {
    margin-top: 1rem;
  }
  /* "Gold Service" wordmark — always visible in gold while the
     surrounding cream text fades in around it. */
  .black-box em {
    font-style: italic;
    font-family: var(--font-display);
    color: var(--color-gold);
    font-weight: 500;
  }
  .black-box-title em {
    font-weight: 400;
  }
  .black-box-note {
    margin-top: 1.5rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-cream) 60%, transparent);
    font-size: 0.9rem;
  }

  /* Paragraph-by-paragraph reveal. Marked :global because the
     .bb-word spans are created at runtime by JS and won't carry
     Astro's scoped-style hash class. */
  :global(.bb-word) {
    display: inline;
    opacity: 0;
    transition: opacity 2.5s var(--ease-out);
    transition-delay: calc(1s + var(--i, 0) * 3s);
  }
  .black-box-inner.is-revealing :global(.bb-word) {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.bb-word) {
      transition-duration: 0.2s;
      transition-delay: 0s;
    }
  }
</style>
