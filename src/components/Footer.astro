---
import pkg from "../../package.json";
const year = new Date().getFullYear();
const version = pkg.version;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <h2 class="footer-motto display display-italic">Where we level the playing field.</h2>
        <p class="footer-name smallcaps">Pro Se Fair Play Mediation, LLC</p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <div>
          <h4>Learn</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Legal</h4>
          <ul>
            <li><a href="/legal/disclaimer">Disclaimer</a></li>
            <li><a href="/legal/terms">Agreement</a></li>
            <li><a href="/legal/privacy">Privacy</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <hr class="rule" />

    <div class="footer-bottom">
      <p class="copy">
        © {year} Pro Se Fair Play Mediation, LLC. All rights reserved.
        <span class="build-version" aria-label="Site build version">v{version}</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy-deep);
    color: var(--color-cream);
    position: relative;
    overflow: hidden;
  }
  .footer::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 30%, var(--color-gold) 70%, transparent);
    opacity: 0.55;
  }
  .footer-inner {
    padding-block: var(--space-2xl) var(--space-lg);
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }
  .footer-motto {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-cream);
    max-width: 20ch;
  }
  .footer-name {
    margin-top: 1.25rem;
    color: var(--color-gold);
    font-size: 0.82rem;
    letter-spacing: 0.24em;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  .footer-nav h4 {
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .footer-nav ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
  .footer-nav a {
    color: color-mix(in srgb, var(--color-cream) 80%, var(--color-navy));
    font-size: 0.95rem;
    position: relative;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--color-gold); }

  .rule {
    background: color-mix(in srgb, var(--color-gold) 35%, transparent);
    margin-block: var(--space-lg);
  }

  .footer-bottom {
    display: flex;
    justify-content: flex-end;
  }
  .copy {
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-cream) 55%, var(--color-navy));
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-end;
  }
  .build-version {
    font-family: var(--font-body);
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--color-cream) 28%, var(--color-navy-deep));
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 780px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--space-xl); }
    .footer-bottom { justify-content: flex-start; }
    .copy { text-align: left; align-items: flex-start; }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
  }
</style>
