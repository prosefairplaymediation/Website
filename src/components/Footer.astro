---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-motto display display-italic">Where we level the playing field.</p>
        <p class="footer-name smallcaps">Pro Se Fair Play Mediation, LLC</p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <div>
          <h4>Practice</h4>
          <ul>
            <li><a href="/services">Services</a></li>
            <li><a href="/book">Book a Consultation</a></li>
            <li><a href="/intake">Client Intake</a></li>
            <li><a href="/pay">Payments</a></li>
          </ul>
        </div>
        <div>
          <h4>Learn</h4>
          <ul>
            <li><a href="/about">About Marie</a></li>
            <li><a href="/blog">Articles</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Legal</h4>
          <ul>
            <li><a href="/legal/disclaimer">Disclaimer</a></li>
            <li><a href="/legal/terms">Terms</a></li>
            <li><a href="/legal/privacy">Privacy</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <hr class="rule" />

    <div class="footer-bottom">
      <p class="disclaimer">
        <strong>Not a law firm.</strong> We are not attorneys and do not provide legal advice or representation.
        We offer document preparation and mediation services for self-represented individuals only.
        We do not represent clients in court.
      </p>
      <p class="copy">© {year} Pro Se Fair Play Mediation, LLC. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-3xl);
    background: var(--color-navy-deep);
    color: var(--color-cream);
    position: relative;
    overflow: hidden;
  }
  .footer::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 30%, var(--color-gold) 70%, transparent);
    opacity: 0.55;
  }
  .footer-inner {
    padding-block: var(--space-2xl) var(--space-lg);
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }
  .footer-motto {
    font-family: var(--font-display);
    font-size: var(--step-3);
    line-height: 1.1;
    color: var(--color-cream);
    max-width: 20ch;
  }
  .footer-name {
    margin-top: 1.25rem;
    color: var(--color-gold);
    font-size: 0.82rem;
    letter-spacing: 0.24em;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .footer-nav h4 {
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .footer-nav ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
  .footer-nav a {
    color: color-mix(in srgb, var(--color-cream) 80%, var(--color-navy));
    font-size: 0.95rem;
    position: relative;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--color-gold); }

  .rule {
    background: color-mix(in srgb, var(--color-gold) 35%, transparent);
    margin-block: var(--space-lg);
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }
  .disclaimer {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-cream) 72%, var(--color-navy));
    max-width: 70ch;
  }
  .disclaimer strong {
    color: var(--color-gold);
    font-weight: 600;
  }
  .copy {
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-cream) 55%, var(--color-navy));
    text-align: right;
    align-self: end;
  }

  @media (max-width: 780px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--space-xl); }
    .footer-bottom { grid-template-columns: 1fr; }
    .copy { text-align: left; }
    .footer-nav { grid-template-columns: repeat(2, 1fr); }
  }
</style>
