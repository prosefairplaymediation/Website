---
const services = [
  { href: "/services/hourly-mediation",  label: "Hourly Mediation" },
  { href: "/services/gold-service",      label: "Gold Service Mediation" },
  { href: "/services/parenting-plan",    label: "Parenting Plan Preparation" },
  { href: "/services/court-packet",      label: "Turn-Key Court Packet" },
  { href: "/services/notary",            label: "Online Notary Services" },
];
---

<header class="nav-root">
  <div class="container nav-inner">
    <a href="/home" class="brand" aria-label="Pro Se Fair Play Mediation — home">
      <span class="brand-mark" aria-hidden="true">
        <img src="/GOLD-LOGO.png" alt="" width="42" height="42" loading="eager" decoding="async" />
      </span>
      <span class="brand-text">
        <span class="brand-name">Pro Se Fair Play</span>
        <span class="brand-sub">Mediation · LLC</span>
        <span class="brand-slogan" aria-hidden="true">Where we level the playing field.</span>
      </span>
    </a>

    <p class="nav-slogan" aria-hidden="true">Where we level the playing field.</p>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        <li><a href="/about">About</a></li>
        <li class="has-dropdown">
          <button
            type="button"
            class="dropdown-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            id="services-trigger"
          >
            Services
            <span class="dropdown-chevron" aria-hidden="true">
              <svg viewBox="0 0 12 8" width="12" height="8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 1.5 L6 6.5 L11 1.5" />
              </svg>
            </span>
          </button>
          <ul class="dropdown-menu" aria-labelledby="services-trigger">
            {services.map(s => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <a class="btn btn-primary nav-cta" href="/book">
        Book Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </nav>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" id="nav-toggle">
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="nav-toggle-label" aria-hidden="true">close</span>
    </button>
  </div>

  <div class="nav-mobile" id="mobile-menu" inert>
    <ul>
      <li><a href="/about">About</a></li>
      <li class="mobile-section-label" aria-hidden="true">Services</li>
      {services.map(s => (
        <li><a class="mobile-sub" href={s.href}>{s.label}</a></li>
      ))}
      <li><a href="/faq">FAQ</a></li>
      <li><a href="/contact">Contact</a></li>
      <li><a class="btn btn-primary mobile-cta" href="/book">Book Consultation <span class="arrow">→</span></a></li>
    </ul>
  </div>
</header>

<style>
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-navy-deep) 94%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: 0.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-navy);
    transition: color 0.25s var(--ease-out);
    flex-shrink: 0;
  }
  .brand-mark {
    display: grid; place-items: center;
    transition: transform 0.5s var(--ease-out);
    transform-origin: 50% 60%;
  }
  .brand-mark img {
    display: block;
    height: auto;
    max-width: 100%;
  }
  .brand:hover .brand-mark {
    transform: rotate(8deg);
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 32;
    font-weight: 500;
    font-size: 1.4rem;
    letter-spacing: 0.01em;
    color: var(--color-gold);
    position: relative;
    padding-bottom: 2px;
    white-space: nowrap;
    background-image: linear-gradient(var(--color-cream), var(--color-cream));
    background-repeat: no-repeat;
    background-size: 0% 2px;
    background-position: 0 100%;
    transition: background-size 0.4s var(--ease-out), color 0.25s var(--ease-out);
  }
  .brand:hover .brand-name {
    background-size: 100% 2px;
    color: var(--color-cream);
  }
  .brand-sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    margin-top: 0.25rem;
    transition: color 0.25s var(--ease-out);
  }
  .brand:hover .brand-sub {
    color: var(--color-gold);
  }

  /* Mobile-only slogan under the brand name (replaces .brand-sub which is
     hidden below 880px). Stays italic gold to echo the desktop nav-slogan. */
  .brand-slogan {
    display: none;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--color-gold);
    margin-top: 0.3rem;
  }

  .nav-slogan {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    letter-spacing: 0.01em;
    color: var(--color-gold);
    white-space: nowrap;
    pointer-events: none;
    margin: 0 1rem;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2.25rem;
  }
  .nav-desktop > ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.75rem;
  }
  .nav-desktop > ul > li > a:not(.nav-cta),
  .nav-desktop .dropdown-trigger {
    font-family: inherit;
    background: none;
    border: 0;
    cursor: pointer;
    font-size: 1.2rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .nav-desktop > ul > li > a:not(.nav-cta)::after,
  .nav-desktop .dropdown-trigger::after {
    content: "";
    position: absolute;
    left: 0; bottom: -2px;
    height: 2px; width: 0;
    background: var(--color-gold);
    transition: width 0.4s var(--ease-out);
  }
  .nav-desktop > ul > li > a:not(.nav-cta):hover,
  .nav-desktop .dropdown-trigger:hover,
  .nav-desktop .has-dropdown:focus-within .dropdown-trigger,
  .nav-desktop .dropdown-trigger[aria-expanded="true"] {
    color: var(--color-gold);
  }
  .nav-desktop > ul > li > a:not(.nav-cta):hover::after,
  .nav-desktop .has-dropdown:hover .dropdown-trigger::after,
  .nav-desktop .has-dropdown:focus-within .dropdown-trigger::after,
  .nav-desktop .dropdown-trigger[aria-expanded="true"]::after {
    width: 100%;
  }
  .dropdown-chevron {
    display: inline-flex;
    color: var(--color-gold);
    transition: transform 0.3s var(--ease-out);
  }
  .has-dropdown:hover .dropdown-chevron,
  .has-dropdown:focus-within .dropdown-chevron,
  .dropdown-trigger[aria-expanded="true"] .dropdown-chevron {
    transform: translateY(2px);
  }

  /* Dropdown menu — desktop only, sits beneath the trigger */
  .has-dropdown {
    position: relative;
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: -0.85rem;
    min-width: 18rem;
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--color-navy-deep);
    border: 1px solid color-mix(in srgb, var(--color-gold) 40%, transparent);
    border-radius: 2px;
    box-shadow: 0 18px 40px -18px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out), visibility 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .has-dropdown:hover .dropdown-menu,
  .has-dropdown:focus-within .dropdown-menu,
  .dropdown-trigger[aria-expanded="true"] + .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-menu li + li {
    border-top: 1px solid color-mix(in srgb, var(--color-gold) 22%, transparent);
  }
  .dropdown-menu a {
    display: block;
    padding: 1rem 1.75rem;
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
    white-space: nowrap;
    position: relative;
    transition: background 0.2s, color 0.2s, padding-left 0.25s var(--ease-out);
  }
  .dropdown-menu a::before {
    content: "";
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 0; height: 50%;
    background: var(--color-gold);
    transition: width 0.25s var(--ease-out);
  }
  .dropdown-menu a:hover,
  .dropdown-menu a:focus-visible {
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 8%, transparent);
    padding-left: 2rem;
  }
  .dropdown-menu a:hover::before,
  .dropdown-menu a:focus-visible::before {
    width: 3px;
  }
  .nav-cta {
    padding: 0.65rem 1.3rem;
    font-size: 1.1rem;
    background: var(--color-gold);
    color: var(--color-navy-deep);
    border-color: var(--color-gold);
  }
  .nav-cta:hover {
    background: var(--color-cream);
    color: var(--color-navy-deep);
    border-color: var(--color-cream);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 4px;
    width: 2.4rem;
    height: 2.4rem;
    transition: border-color 0.25s var(--ease-out), padding 0.25s var(--ease-out), width 0.25s var(--ease-out), height 0.25s var(--ease-out);
  }
  .nav-toggle-bars {
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle-bars span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--color-cream);
    transition: transform 0.35s var(--ease-out), opacity 0.25s;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .nav-toggle-label {
    display: none;
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cream);
    margin-top: 0.3rem;
    line-height: 1;
  }
  .nav-toggle[aria-expanded="true"] {
    border-color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    width: auto;
    height: auto;
    padding: 0.45rem 0.55rem 0.4rem;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-label {
    display: block;
  }

  .nav-mobile {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s var(--ease-in-out);
    background: var(--color-navy-deep);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  }
  .nav-mobile:not([inert]) {
    max-height: 48rem;
  }
  .nav-mobile ul {
    list-style: none;
    padding: 0.5rem clamp(1.25rem, 4vw, 3rem) 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: var(--container);
    margin: 0 auto;
  }
  .nav-mobile a:not(.mobile-cta) {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 18%, transparent);
    font-family: var(--font-display);
    font-variation-settings: "opsz" 48;
    font-size: 1.5rem;
    color: var(--color-cream);
    transition: color 0.2s;
  }
  .nav-mobile a:not(.mobile-cta):hover {
    color: var(--color-gold);
  }
  /* Services sub-list in mobile menu */
  .nav-mobile .mobile-section-label {
    margin-top: 0.5rem;
    padding: 0.5rem 0 0;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-gold);
    border-bottom: none;
  }
  .nav-mobile a.mobile-sub {
    padding-left: 1.25rem;
    font-size: 1.2rem;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
  }
  .mobile-cta {
    margin-top: 0.75rem;
    justify-content: center;
    width: 100%;
    background: var(--color-gold);
    color: var(--color-navy-deep);
    border-color: var(--color-gold);
  }

  /* Hide nav slogan before things get cramped — below ~1255px the slogan
     squeezes the brand text and forces "Pro Se Fair Play" / "Mediation · LLC"
     to wrap awkwardly. */
  @media (max-width: 1255px) {
    .nav-slogan { display: none; }
  }

  @media (max-width: 880px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
    .brand-sub { display: none; }
    .brand-slogan { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
      if (expanded) {
        menu.setAttribute("inert", "");
      } else {
        menu.removeAttribute("inert");
      }
    });
    menu.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open menu");
        menu.setAttribute("inert", "");
      });
    });
  }

  // Desktop Services dropdown — hover handles itself via CSS,
  // this gives click/keyboard control too.
  const dropdownTrigger = document.getElementById("services-trigger");
  if (dropdownTrigger) {
    const closeDropdown = () => dropdownTrigger.setAttribute("aria-expanded", "false");

    dropdownTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = dropdownTrigger.getAttribute("aria-expanded") === "true";
      dropdownTrigger.setAttribute("aria-expanded", String(!open));
    });

    document.addEventListener("click", (e) => {
      const wrapper = dropdownTrigger.closest(".has-dropdown");
      if (wrapper && !wrapper.contains(e.target as Node)) closeDropdown();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeDropdown();
    });

    // Close when any dropdown item is clicked (so navigation feels clean)
    const wrapper = dropdownTrigger.closest(".has-dropdown");
    if (wrapper) {
      wrapper.querySelectorAll(".dropdown-menu a").forEach(a => {
        a.addEventListener("click", () => closeDropdown());
      });
    }
  }
</script>
