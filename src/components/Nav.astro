---
const links = [
  { href: "/services", label: "Services" },
  { href: "/book",     label: "Book" },
  { href: "/blog",     label: "Blog" },
  { href: "/faq",      label: "FAQ" },
  { href: "/contact",  label: "Contact" },
];
---

<header class="nav-root">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="Pro Se Fair Play Mediation — home">
      <span class="brand-mark" aria-hidden="true">
        <!-- Simplified scales glyph in the brand color -->
        <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 V34" />
          <path d="M8 34 H32" />
          <path d="M6 14 L14 14" />
          <path d="M26 14 L34 14" />
          <path d="M10 14 L6 24 Q10 26 14 24 Z" />
          <path d="M30 14 L26 24 Q30 26 34 24 Z" />
          <circle cx="20" cy="8" r="1.6" fill="currentColor" />
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">Pro Se Fair Play</span>
        <span class="brand-sub">Mediation · LLC</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {links.map(l => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
      <a class="btn btn-primary nav-cta" href="/book">
        Book Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </nav>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="mobile-menu" aria-hidden="true">
    <ul>
      {links.map(l => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
      <li><a class="btn btn-primary mobile-cta" href="/book">Book Consultation <span class="arrow">→</span></a></li>
    </ul>
  </div>
</header>

<style>
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-cream) 92%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--color-divider);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: 1.05rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-navy);
  }
  .brand-mark {
    color: var(--color-gold);
    display: grid; place-items: center;
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: 0.01em;
    color: var(--color-navy);
  }
  .brand-sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2.25rem;
  }
  .nav-desktop ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.75rem;
  }
  .nav-desktop a:not(.nav-cta) {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s;
  }
  .nav-desktop a:not(.nav-cta)::after {
    content: "";
    position: absolute;
    left: 0; bottom: -2px;
    height: 1px; width: 0;
    background: var(--color-gold);
    transition: width 0.4s var(--ease-out);
  }
  .nav-desktop a:not(.nav-cta):hover {
    color: var(--color-navy);
  }
  .nav-desktop a:not(.nav-cta):hover::after {
    width: 100%;
  }
  .nav-cta { padding: 0.7rem 1.25rem; font-size: 0.875rem; }

  .nav-toggle {
    display: none;
    width: 2.4rem; height: 2.4rem;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .nav-toggle span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--color-ink);
    transition: transform 0.35s var(--ease-out), opacity 0.25s;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .nav-mobile {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s var(--ease-in-out);
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
  }
  .nav-mobile[aria-hidden="false"] {
    max-height: 32rem;
  }
  .nav-mobile ul {
    list-style: none;
    padding: 0.5rem clamp(1.25rem, 4vw, 3rem) 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: var(--container);
    margin: 0 auto;
  }
  .nav-mobile a:not(.mobile-cta) {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-divider);
    font-family: var(--font-display);
    font-variation-settings: "opsz" 48;
    font-size: 1.5rem;
    color: var(--color-ink);
  }
  .mobile-cta {
    margin-top: 0.75rem;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 880px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
    .brand-sub { display: none; }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      toggle.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
      menu.setAttribute("aria-hidden", String(expanded));
    });
    menu.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open menu");
        menu.setAttribute("aria-hidden", "true");
      });
    });
  }
</script>
