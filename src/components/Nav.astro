---
const services = [
  { href: "/services/hourly-mediation",  label: "Hourly Mediation" },
  { href: "/services/gold-service",      label: "Gold Service Mediation" },
  { href: "/services/parenting-plan",    label: "Parenting Plan Preparation" },
  { href: "/services/court-packet",      label: "Turn-Key Court Packet" },
  { href: "/services/notary",            label: "Online Notary Services" },
];
---

<header class="nav-root">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="Pro Se Fair Play Mediation — home">
      <span class="brand-mark" aria-hidden="true">
        <img src="/GOLD-LOGO.png" alt="" width="42" height="42" loading="eager" decoding="async" />
      </span>
      <span class="brand-text">
        <span class="brand-name">Pro Se Fair Play</span>
        <span class="brand-sub">Mediation · LLC</span>
      </span>
    </a>

    <p class="nav-slogan">Where we level the playing field.</p>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/process">The Mediation Process</a></li>
        <li class="has-dropdown">
          <button
            type="button"
            class="dropdown-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            id="services-trigger"
          >
            Services
            <span class="dropdown-chevron" aria-hidden="true">
              <svg viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 2.5 L7 7.5 L12 2.5" />
              </svg>
            </span>
          </button>
          <ul class="dropdown-menu" aria-labelledby="services-trigger">
            {services.map(s => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/documents">Documents</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <a class="btn btn-primary nav-cta" href="/book">
        Book Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </nav>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" id="nav-toggle">
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="nav-toggle-label" aria-hidden="true">close</span>
    </button>
  </div>

  <div class="nav-mobile" id="mobile-menu" inert>
    <ul>
      <li><a href="/about">About</a></li>
      <li><a href="/process">The Mediation Process</a></li>
      <li class="mobile-section-label" aria-hidden="true">Services</li>
      {services.map(s => (
        <li><a class="mobile-sub" href={s.href}>{s.label}</a></li>
      ))}
      <li><a href="/faq">FAQ</a></li>
      <li><a href="/documents">Documents</a></li>
      <li><a href="/contact">Contact</a></li>
      <li><a class="btn btn-primary mobile-cta" href="/book">Book Consultation <span class="arrow">→</span></a></li>
    </ul>
  </div>
</header>

<style>
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-navy-deep) 94%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  }
  /* Brand stage-left with the slogan tucked beneath it, full nav
     right-aligned. (The long "The Mediation Process" link makes a
     centered-slogan row overflow, so this is the layout at every
     desktop width; the mobile query below swaps the right column to
     the hamburger toggle.) */
  .nav-inner {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    grid-template-areas:
      "brand   desktop"
      "slogan  desktop";
    align-items: center;
    row-gap: 0.3rem;
    column-gap: var(--space-md);
    padding-block: 0.75rem;
  }
  .brand {
    grid-area: brand;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-navy);
    transition: color 0.25s var(--ease-out);
    flex-shrink: 0;
  }
  /* Logo floats out of the brand flow and centers vertically against
     the full banner height (both the name row and the slogan row),
     at every width. Brand text and slogan are padded to clear it. */
  .brand-mark {
    position: absolute;
    left: clamp(1.25rem, 4vw, 3rem);
    top: 50%;
    transform: translateY(-50%);
    display: grid; place-items: center;
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    transition: transform 0.5s var(--ease-out);
    transform-origin: 50% 60%;
  }
  .brand-mark img {
    display: block;
    width: 42px;
    height: 42px;
    max-width: none;
  }
  .brand:hover .brand-mark {
    transform: translateY(-50%) rotate(8deg);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
    padding-left: calc(42px + 0.7rem);
  }
  .brand-name {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 32;
    font-weight: 500;
    font-size: 1.4rem;
    letter-spacing: 0.01em;
    color: var(--color-gold);
    position: relative;
    padding-bottom: 2px;
    white-space: nowrap;
    background-image: linear-gradient(var(--color-cream), var(--color-cream));
    background-repeat: no-repeat;
    background-size: 0% 2px;
    background-position: 0 100%;
    transition: background-size 0.4s var(--ease-out), color 0.25s var(--ease-out);
  }
  .brand:hover .brand-name {
    background-size: 100% 2px;
    color: var(--color-cream);
  }
  .brand-sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    margin-top: 0.25rem;
    transition: color 0.25s var(--ease-out);
  }
  .brand:hover .brand-sub {
    color: var(--color-gold);
  }

  .nav-slogan {
    grid-area: slogan;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.01em;
    color: var(--color-gold);
    pointer-events: none;
    margin: 0;
    padding-left: calc(42px + 0.7rem);
    white-space: nowrap;
  }

  .nav-desktop {
    grid-area: desktop;
    justify-self: end;
    align-self: center;
    display: flex;
    align-items: center;
    gap: 2.25rem;
  }
  .nav-desktop > ul {
    list-style: none;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .nav-desktop > ul > li > a:not(.nav-cta),
  .nav-desktop .dropdown-trigger {
    font-family: inherit;
    background: none;
    border: 0;
    cursor: pointer;
    font-size: 1.2rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .nav-desktop > ul > li > a:not(.nav-cta)::after,
  .nav-desktop .dropdown-trigger::after {
    content: "";
    position: absolute;
    left: 0; bottom: -2px;
    height: 2px; width: 0;
    background: var(--color-gold);
    transition: width 0.4s var(--ease-out);
  }
  .nav-desktop > ul > li > a:not(.nav-cta):hover,
  .nav-desktop .dropdown-trigger:hover,
  .nav-desktop .has-dropdown:focus-within .dropdown-trigger,
  .nav-desktop .dropdown-trigger[aria-expanded="true"] {
    color: var(--color-gold);
  }
  .nav-desktop > ul > li > a:not(.nav-cta):hover::after,
  .nav-desktop .has-dropdown:hover .dropdown-trigger::after,
  .nav-desktop .has-dropdown:focus-within .dropdown-trigger::after,
  .nav-desktop .dropdown-trigger[aria-expanded="true"]::after {
    width: 100%;
  }
  .dropdown-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    flex-shrink: 0;
    width: 14px;
    height: 10px;
    transition: transform 0.3s var(--ease-out);
  }
  .dropdown-chevron svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .has-dropdown:hover .dropdown-chevron,
  .has-dropdown:focus-within .dropdown-chevron,
  .dropdown-trigger[aria-expanded="true"] .dropdown-chevron {
    transform: translateY(2px);
  }

  /* Dropdown menu — desktop only, sits beneath the trigger */
  .has-dropdown {
    position: relative;
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: -0.85rem;
    min-width: 18rem;
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--color-navy-deep);
    border: 1px solid color-mix(in srgb, var(--color-gold) 40%, transparent);
    border-radius: 2px;
    box-shadow: 0 18px 40px -18px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out), visibility 0.25s;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Invisible hover bridge — extends the menu's hoverable area up
     into the 0.5rem gap between trigger and menu so a slow pointer
     moving from trigger to menu doesn't cross dead space and lose
     :hover (WCAG 1.4.13 Hoverable). */
  .dropdown-menu::before {
    content: "";
    position: absolute;
    top: -0.5rem;
    left: 0;
    right: 0;
    height: 0.5rem;
  }
  .has-dropdown:hover .dropdown-menu,
  .has-dropdown:focus-within .dropdown-menu,
  .dropdown-trigger[aria-expanded="true"] + .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* Escape sets this class on the wrapper to force the menu closed
     even while focus-within or :hover would otherwise keep it open.
     The class is cleared by JS when the user moves pointer out or
     focus leaves the wrapper, so the next interaction works normally. */
  .has-dropdown.is-dismissed .dropdown-menu {
    opacity: 0 !important;
    visibility: hidden !important;
    transform: translateY(-4px) !important;
  }
  .dropdown-menu li + li {
    border-top: 1px solid color-mix(in srgb, var(--color-gold) 22%, transparent);
  }
  .dropdown-menu a {
    display: block;
    padding: 1rem 1.75rem;
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
    white-space: nowrap;
    position: relative;
    transition: background 0.2s, color 0.2s, padding-left 0.25s var(--ease-out);
  }
  .dropdown-menu a::before {
    content: "";
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 0; height: 50%;
    background: var(--color-gold);
    transition: width 0.25s var(--ease-out);
  }
  .dropdown-menu a:hover,
  .dropdown-menu a:focus-visible {
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 8%, transparent);
    padding-left: 2rem;
  }
  .dropdown-menu a:hover::before,
  .dropdown-menu a:focus-visible::before {
    width: 3px;
  }
  .nav-cta {
    padding: 0.65rem 1.3rem;
    font-size: 1.1rem;
    background: var(--color-gold);
    color: var(--color-navy-deep);
    border-color: var(--color-gold);
  }
  .nav-cta:hover {
    background: var(--color-cream);
    color: var(--color-navy-deep);
    border-color: var(--color-cream);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 4px;
    width: 3rem;
    height: 3rem;
    transition: border-color 0.25s var(--ease-out), padding 0.25s var(--ease-out), width 0.25s var(--ease-out), height 0.25s var(--ease-out);
  }
  .nav-toggle-bars {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle-bars span {
    display: block;
    width: 28px; height: 2.5px;
    background: var(--color-cream);
    border-radius: 1px;
    transition: transform 0.35s var(--ease-out), opacity 0.25s;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(1) { transform: translateY(8.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bars span:nth-child(3) { transform: translateY(-8.5px) rotate(-45deg); }

  .nav-toggle-label {
    display: none;
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cream);
    margin-top: 0.3rem;
    line-height: 1;
  }
  .nav-toggle[aria-expanded="true"] {
    border-color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    width: auto;
    height: auto;
    padding: 0.45rem 0.55rem 0.4rem;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-label {
    display: block;
  }

  .nav-mobile {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s var(--ease-in-out);
    background: var(--color-navy-deep);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  }
  .nav-mobile:not([inert]) {
    /* Cap at viewport minus sticky nav row so the menu never extends past
       the screen on phones. dvh accounts for mobile browser chrome. */
    max-height: min(48rem, calc(100dvh - 5rem));
    /* Allow internal scroll when the menu's content exceeds the cap; the
       contain value blocks scroll chaining to the body underneath. */
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }
  .nav-mobile ul {
    list-style: none;
    padding: 0.5rem clamp(1.25rem, 4vw, 3rem) 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: var(--container);
    margin: 0 auto;
  }
  .nav-mobile a:not(.mobile-cta) {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 18%, transparent);
    font-family: var(--font-display);
    font-variation-settings: "opsz" 48;
    font-size: 1.5rem;
    color: var(--color-cream);
    transition: color 0.2s;
  }
  .nav-mobile a:not(.mobile-cta):hover {
    color: var(--color-gold);
  }
  /* Services sub-list in mobile menu */
  .nav-mobile .mobile-section-label {
    margin-top: 0.5rem;
    padding: 0.5rem 0 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-gold);
    border-bottom: none;
  }
  .nav-mobile a.mobile-sub {
    padding-left: 1.25rem;
    font-size: 1.2rem;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
  }
  .mobile-cta {
    margin-top: 0.75rem;
    justify-content: center;
    width: 100%;
    background: var(--color-gold);
    color: var(--color-navy-deep);
    border-color: var(--color-gold);
  }

  /* Mobile (~≤1240px): hide desktop nav, show hamburger. Slogan
     still sits under the brand block; the right column becomes the
     toggle button instead of the desktop nav. Breakpoint sits where
     the desktop layout actually starts overflowing (book button +
     slogan + nav items + the Process entry stop fitting). */
  @media (max-width: 1240px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
    /* Swap the right column from the nav to the hamburger toggle. The
       brand / slogan / centered-logo treatment is inherited from the
       base rules above. */
    .nav-inner {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "brand  toggle"
        "slogan toggle";
      row-gap: 0.1rem;
    }
    /* Hamburger spans both rows and centers against the full banner. */
    .nav-toggle { grid-area: toggle; align-self: center; }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    // Lock body scroll while the mobile menu is open so swipes on the
    // menu can't bleed through to the page underneath. Restored when
    // the menu closes (toggle click or link click).
    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Open menu");
      menu.setAttribute("inert", "");
      document.body.style.overflow = "";
    };
    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      toggle.setAttribute("aria-label", "Close menu");
      menu.removeAttribute("inert");
      document.body.style.overflow = "hidden";
    };
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      if (expanded) closeMenu(); else openMenu();
    });
    menu.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => closeMenu());
    });
  }

  // Desktop Services dropdown — CSS handles the visual reveal on
  // :hover and :focus-within. The JS here keeps aria-expanded in sync
  // so screen readers see the correct state regardless of which trigger
  // opened the menu (click, hover, or keyboard focus). WCAG 1.4.13
  // also requires dismiss via Escape and persistence while pointer
  // hovers the menu — both handled below.
  const dropdownTrigger = document.getElementById("services-trigger");
  if (dropdownTrigger) {
    const wrapper = dropdownTrigger.closest(".has-dropdown");
    const setExpanded = (v) => dropdownTrigger.setAttribute("aria-expanded", String(v));

    dropdownTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = dropdownTrigger.getAttribute("aria-expanded") === "true";
      setExpanded(!open);
    });

    if (wrapper) {
      // Hover opens the menu via CSS; mirror to aria-expanded so the
      // accessibility tree matches the visual state. is-dismissed
      // is NOT cleared on focusin — that event fires when Escape
      // moves focus from a menu item back to the trigger, and
      // clearing then would reopen the menu we just dismissed.
      // Mouseenter and focusout (leaving the wrapper) clear it.
      wrapper.addEventListener("mouseenter", () => {
        wrapper.classList.remove("is-dismissed");
        setExpanded(true);
      });
      wrapper.addEventListener("mouseleave", () => {
        wrapper.classList.remove("is-dismissed");
        setExpanded(false);
      });
      wrapper.addEventListener("focusin", () => setExpanded(true));
      wrapper.addEventListener("focusout", (e) => {
        if (!wrapper.contains(e.relatedTarget as Node)) {
          wrapper.classList.remove("is-dismissed");
          setExpanded(false);
        }
      });
    }

    document.addEventListener("click", (e) => {
      if (wrapper && !wrapper.contains(e.target as Node)) setExpanded(false);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        setExpanded(false);
        // Force the menu closed even though :hover / :focus-within
        // would otherwise keep it open. Class is cleared by the
        // mouse/focus handlers above on the next interaction.
        if (wrapper) wrapper.classList.add("is-dismissed");
        // Return focus to the trigger so the user knows where they are.
        if (document.activeElement && wrapper?.contains(document.activeElement)) {
          dropdownTrigger.focus();
        }
      }
    });

    // Close when any dropdown item is clicked (so navigation feels clean)
    if (wrapper) {
      wrapper.querySelectorAll(".dropdown-menu a").forEach(a => {
        a.addEventListener("click", () => setExpanded(false));
      });
    }
  }
</script>
