---
import BaseLayout from "../../layouts/BaseLayout.astro";

const formats = [
  {
    label: "PDF",
    sublabel: "Portable Document · ~111 KB",
    href: "/Pro_Se_Fair_Play_Engagement_Agreement.pdf",
  },
  {
    label: "Docx",
    sublabel: "Microsoft Word · ~106 KB",
    href: "/Pro_Se_Fair_Play_Engagement_Agreement.docx",
  },
];
---

<BaseLayout
  title="Terms · Pro Se Fair Play Mediation"
  description="Engagement Agreement for Pro Se Fair Play Mediation & Document Preparation Services, LLC. Available for download as a Word document."
>
  <!-- ========================== HEADER ========================== -->
  <header class="legal-header">
    <div class="container legal-header-inner">
      <p class="kicker reveal reveal-d1">
        <a href="/" class="back-link">
          <span class="arrow-left" aria-hidden="true">←</span>
          Home
        </a>
        <span class="kicker-sep" aria-hidden="true">·</span>
        Legal
      </p>
      <h1 class="display legal-title reveal reveal-d2">
        Engagement <span class="display-italic">Agreement</span>
      </h1>
      <p class="lede reveal reveal-d3">
        The Engagement Agreement governing services with Pro Se Fair Play
        Mediation, LLC is provided as a downloadable Word document.
      </p>
    </div>
  </header>

  <!-- ========================== DOWNLOAD CARDS ========================== -->
  <section class="legal-body">
    <div class="container-narrow">
      <p class="formats-label smallcaps">Choose a format</p>

      <div class="download-stack">
        {formats.map((f) => (
          <div class="download-card">
            <div class="download-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 5 H20 L26 11 V27 H8 Z" />
                <path d="M20 5 V11 H26" />
                <path d="M16 16 V23 M12 19 L16 23 L20 19" />
              </svg>
            </div>
            <div class="download-info">
              <p class="download-label smallcaps">{f.label}</p>
              <p class="download-sub">{f.sublabel}</p>
            </div>
            <a class="btn btn-primary download-btn" href={f.href} download>
              Download
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 1rem, 6rem) clamp(2rem, 3vw, 3rem);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
    overflow: hidden;
  }
  .legal-header-inner { position: relative; max-width: 64rem; }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-gold-deep);
    font-weight: 600;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-navy); }
  .arrow-left { transition: transform 0.3s var(--ease-out); }
  .back-link:hover .arrow-left { transform: translateX(-3px); }
  .kicker-sep { color: var(--color-divider); margin-inline: 0.4rem; }
  .legal-title {
    margin-top: 1rem;
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-navy);
    letter-spacing: -0.025em;
    font-weight: 400;
  }
  .legal-title .display-italic {
    color: var(--color-gold-deep);
    font-weight: 400;
  }
  .legal-header .lede {
    margin-top: 1.5rem;
    max-width: 60ch;
  }

  .legal-body {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream);
  }

  .formats-label {
    font-size: 0.78rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.22em;
    margin-bottom: 1.25rem;
    display: block;
  }
  .download-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .download-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
    border-radius: 4px;
    position: relative;
    box-shadow:
      0 1px 2px rgba(18, 33, 74, 0.04),
      0 12px 32px -16px rgba(18, 33, 74, 0.18);
  }
  .download-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 4rem; height: 2px;
    background: var(--color-gold);
  }
  .download-icon {
    color: var(--color-gold-deep);
    display: grid;
    place-items: center;
    width: 3rem; height: 3rem;
  }
  .download-info { min-width: 0; }
  .download-label {
    font-family: var(--font-display);
    font-size: 1.45rem;
    color: var(--color-navy);
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
    display: block;
    text-transform: none;
  }
  .download-sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-slate);
    font-style: italic;
    line-height: 1.4;
  }
  .download-btn {
    white-space: nowrap;
  }

  .legal-note {
    margin-top: 2rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-slate);
    font-style: italic;
    max-width: 60ch;
  }
  .legal-note a {
    color: var(--color-navy);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
    background-repeat: no-repeat;
    background-size: 100% 1px;
    background-position: 0 92%;
    font-style: normal;
  }
  .legal-note a:hover {
    color: var(--color-gold-deep);
  }

  @media (max-width: 600px) {
    .legal-title { font-size: clamp(2.25rem, 1.8rem + 3vw, 3.5rem); }
    .download-card {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .download-btn { justify-self: flex-start; }
  }
</style>
