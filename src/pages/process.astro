---
import BaseLayout from "../layouts/BaseLayout.astro";

const phases = [
  {
    num: "01",
    eyebrow: "Phase One",
    title: "Pre-Session Preparation",
    body: [
      `Before the session, both parties are contacted to confirm the issues in dispute, identify any financial disclosure documents or supporting information that may be needed, confirm payment arrangements, and receive Zoom access instructions — so both parties arrive prepared to negotiate without unnecessary administrative delays.`,
    ],
  },
  {
    num: "02",
    eyebrow: "Phase Two",
    title: "Structured Negotiation",
    body: [
      `The session begins with both parties present to explain the mediation process and review the confidentiality protections provided under Florida Statute §44.405.`,
      `Under Florida law, communications made during mediation are confidential and generally may not be disclosed or used as evidence in court proceedings, allowing both parties to engage in open and productive settlement discussions.`,
      `Private caucuses may then be conducted with each party separately to identify priorities, clarify positions, and narrow contested issues — so both parties can negotiate from an informed position without direct confrontation driving the session off course.`,
    ],
  },
  {
    num: "03",
    eyebrow: "Phase Three",
    title: "Agreement, Drafting & Submission",
    body: [
      `When both parties reach an agreement, a written Mediated Settlement Agreement is prepared reflecting the terms agreed upon during mediation.`,
      `Both parties review and sign the agreement before the session concludes. As part of our concierge mediation service, the executed Mediated Settlement Agreement is submitted to the court on the parties’ behalf for incorporation into a final judgment or order, when appropriate.`,
    ],
  },
];

const outcomes = [
  {
    label: "Outcome One",
    title: "Full Agreement",
    summary: `Both parties reach a written agreement on all contested issues.`,
    body: `A Mediated Settlement Agreement is prepared, both parties sign before the session concludes, and the executed agreement is submitted to the court for incorporation into the final judgment.`,
  },
  {
    label: "Outcome Two",
    title: "Partial Agreement",
    summary: `Both parties reach a written agreement on some contested issues, but not all.`,
    body: `The partial mediated agreement is binding on the issues it resolves, allowing the court to address only the remaining unresolved matters. This often reduces hearing time, litigation costs, and future conflict.`,
  },
  {
    label: "Outcome Three",
    title: "Impasse",
    summary: `Both parties are unable to reach agreement on one or more contested issues.`,
    body: `Mediation concludes in impasse, and the case proceeds through the court process for resolution of the remaining disputes. An impasse does not affect either party’s legal rights or standing before the court.`,
  },
];
---

<BaseLayout
  title="The Mediation Process · Pro Se Fair Play Mediation"
  description="How a Pro Se mediation session is structured — from pre-session preparation through structured negotiation to a signed, court-submitted agreement — and what each possible outcome means for your case."
>
  <!-- ========================== HEADER ========================== -->
  <header class="legal-header">
    <div class="container legal-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        The Mediation Process
      </p>
      <h1 class="display legal-title reveal reveal-d2">
        How mediation <span class="display-italic">works</span>.
      </h1>
      <p class="lede reveal reveal-d3">
        Pro Se mediation follows a structured three-phase process that helps
        parties work toward a written agreement in a professional,
        confidential, and efficient setting.
      </p>
    </div>
  </header>

  <!-- ========================== PHASES ========================== -->
  <section class="process-phases">
    <div class="container-narrow">
      <ol class="process-list" role="list">
        {phases.map((phase) => (
          <li class="process-step">
            <div class="process-step-rail" aria-hidden="true">
              <span class="process-step-num display">{phase.num}</span>
            </div>
            <div class="process-step-body">
              <p class="process-step-eyebrow">{phase.eyebrow}</p>
              <h2 class="display process-step-title">{phase.title}</h2>
              {phase.body.map((p) => <p>{p}</p>)}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ========================== OUTCOMES ========================== -->
  <section class="process-outcomes">
    <div class="container-narrow">
      <div class="process-outcomes-head">
        <p class="kicker">
          <span class="kicker-dot" aria-hidden="true"></span>
          Possible Outcomes
        </p>
        <h2 class="display process-outcomes-title">
          What happens if mediation doesn’t reach
          <span class="display-italic">full agreement</span>.
        </h2>
        <p class="lede process-outcomes-lede">
          Mediation generally produces one of three outcomes, so parties
          understand what each outcome means for their case before the
          session begins.
        </p>
      </div>

      <div class="outcome-flow">
        {outcomes.map((o) => (
          <article class="outcome">
            <h3 class="display outcome-title">{o.title}</h3>
            <p class="outcome-summary">{o.summary}</p>
            <p class="outcome-body">{o.body}</p>
          </article>
        ))}
      </div>

      <p class="process-note">
        Most mediation sessions produce substantial progress toward
        resolution. Cases involving multiple financial disputes, complex
        parenting issues, or high-conflict dynamics may require additional
        sessions before full agreement is reached.
      </p>
    </div>
  </section>

  <!-- ========================== CLOSING CTA ========================== -->
  <section class="process-close">
    <div class="container-narrow process-close-inner">
      <p class="kicker process-close-kicker">Ready to begin?</p>
      <h2 class="display process-close-title">
        Take the <span class="display-italic">first step</span> toward resolution.
      </h2>
      <p class="lede process-close-lede">
        Schedule a consultation to talk through your situation and find out
        whether mediation is the right path forward.
      </p>
      <a class="btn btn-primary process-close-cta" href="/book">
        Book a Free Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     HEADER — mirrors /faq and the legal pages
     ============================================================ */
  .legal-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 1rem, 6rem) clamp(2rem, 3vw, 3rem);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
    overflow: hidden;
  }
  .legal-header-inner { position: relative; max-width: 64rem; }
  .legal-title {
    margin-top: 1rem;
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-navy);
    letter-spacing: -0.025em;
    max-width: 18ch;
    font-weight: 400;
  }
  .legal-title .display-italic {
    color: var(--color-gold-deep);
    font-weight: 400;
  }
  .legal-header .lede {
    margin-top: 1.5rem;
    max-width: 60ch;
  }

  /* ============================================================
     PHASES — numbered process steps
     ============================================================ */
  .process-phases {
    padding-block: var(--space-md) var(--space-2xl);
    background: var(--color-cream);
  }
  .process-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .process-step {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding-block: clamp(2rem, 4vw, 3rem);
  }
  .process-step + .process-step {
    border-top: 1px solid var(--color-divider);
  }
  .process-step:first-child {
    padding-top: 0;
  }
  /* Number rail — big gold numeral with a vertical tick beneath it */
  .process-step-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .process-step-num {
    /* Fixed, centred box so every rail is the same width regardless of
       which digits it holds — otherwise the narrower "01" pulls Phase
       One's body left of the others. */
    width: 2.5ch;
    text-align: center;
    font-size: clamp(2.5rem, 1.8rem + 3vw, 3.75rem);
    line-height: 1;
    color: var(--color-gold-deep);
    font-weight: 500;
    font-variation-settings: "opsz" 48;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .process-step-rail::after {
    content: "";
    flex: 1;
    width: 1px;
    background: linear-gradient(var(--color-gold), transparent);
    min-height: 1.5rem;
  }

  .process-step-eyebrow {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
    margin-bottom: 0.6rem;
  }
  .process-step-title {
    font-size: var(--step-3);
    line-height: 1.08;
    color: var(--color-navy);
    letter-spacing: -0.015em;
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .process-step-body p:not(.process-step-eyebrow) {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }
  .process-step-body p:not(.process-step-eyebrow) + p { margin-top: 1.1rem; }

  /* ============================================================
     OUTCOMES — three result cards
     ============================================================ */
  .process-outcomes {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-divider);
  }
  .process-outcomes-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .process-outcomes-title {
    margin-top: 1rem;
    font-size: var(--step-4);
    line-height: 1.05;
    color: var(--color-navy);
    letter-spacing: -0.02em;
    max-width: 20ch;
    font-weight: 400;
  }
  .process-outcomes-title .display-italic { color: var(--color-gold-deep); }
  .process-outcomes-lede {
    margin-top: 1.5rem;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }

  /* Outcomes flow as natural prose — heading + paragraphs, divided
     by a hairline, matching the rhythm of the phase list above. */
  .outcome-flow {
    display: flex;
    flex-direction: column;
  }
  .outcome {
    padding-block: clamp(1.75rem, 3.5vw, 2.5rem);
  }
  .outcome + .outcome {
    border-top: 1px solid var(--color-divider);
  }
  .outcome-title {
    font-size: var(--step-3);
    line-height: 1.1;
    color: var(--color-navy);
    letter-spacing: -0.015em;
    font-weight: 400;
    margin-bottom: 0.85rem;
  }
  .outcome-summary {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-navy);
    font-weight: 500;
    max-width: 64ch;
  }
  .outcome-body {
    margin-top: 0.85rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 64ch;
  }

  .process-note {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    max-width: 64ch;
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    padding-top: 1.5rem;
    border-top: 2px solid var(--color-gold);
  }

  /* ============================================================
     CLOSING CTA — matches the /faq closing block
     ============================================================ */
  .process-close {
    position: relative;
    padding-block: var(--space-3xl);
    background:
      radial-gradient(ellipse at 80% 50%, rgba(196, 154, 75, 0.14), transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(196, 154, 75, 0.08), transparent 45%),
      var(--color-cream);
    color: var(--color-ink);
    overflow: hidden;
    border-top: 1px solid var(--color-divider);
  }
  .process-close::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.7;
  }
  .process-close-kicker { color: var(--color-gold-deep); }
  .process-close-title {
    margin-block: 1rem 1.5rem;
    font-size: var(--step-4);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-navy);
    max-width: 22ch;
  }
  .process-close-title .display-italic { color: var(--color-gold-deep); }
  .process-close-lede {
    color: var(--color-ink-soft);
    max-width: 56ch;
  }
  .process-close-cta {
    margin-top: 2rem;
    background: var(--color-navy);
    color: var(--color-cream);
    border-color: var(--color-navy);
  }
  .process-close-cta:hover {
    background: var(--color-navy-deep);
    border-color: var(--color-gold);
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 600px) {
    .legal-title { font-size: clamp(2.25rem, 1.8rem + 3vw, 3.5rem); }
    .process-step {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    /* Mobile drops the big 01 / 02 / 03 numerals — they only read well
       with the desktop two-column rail, and mobile is what the client
       actually reviews. */
    .process-step-rail { display: none; }
    .process-outcomes-title { font-size: clamp(1.75rem, 1.4rem + 2.5vw, 2.5rem); }
  }
</style>
