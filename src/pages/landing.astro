---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl = "https://calendly.com/prosefairplaymediation-info/free-consultation";
const email = "info@prosefairplaymediation.com";
const phoneVanity = "1 (866) 88-FORPROSE";
const phoneTel = "+18668836777";
const phoneDigits = "1-866-883-6777";
---

<BaseLayout
  title="Pro Se Fair Play Mediation"
  description="Florida family law support, mediation and court-ready document preparation for self-represented parties. Book a free 15-minute consultation."
>
  <!-- ========================== HEADER ========================== -->
  <header class="landing-header">
    <div class="container landing-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        Welcome to Pro Se Fair Play Mediation
      </p>
      <h1 class="display landing-title reveal reveal-d2">
        A level playing field<span class="display-italic">.</span><br />
        <span class="display-italic">One conversation away</span><span class="display-italic">.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        Florida family law support: mediation and court-ready documents. Free consultations
      </p>
    </div>
  </header>

  <!-- ========================== SERVICES ========================== -->
  <section class="landing-services">
    <div class="container">
      <ul class="landing-services-grid" role="list">

        <li class="landing-card">
          <div class="landing-card-head">
            <span class="landing-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="m11 17 2 2a1 1 0 1 0 3-3" />
                <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" />
                <path d="m21 3 1 11h-2" />
                <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" />
                <path d="M3 4h8" />
              </svg>
            </span>
            <h2 class="landing-card-title display">Hourly Mediation</h2>
          </div>
          <p class="landing-card-price smallcaps">$600 / hr</p>
          <p class="landing-card-body">
            A neutral, guided conversation where both parties work
            toward a mutually acceptable resolution. Conducted via
            Zoom, structured, confidential.
          </p>
          <a
            href="/services/hourly-mediation"
            class="landing-card-link"
            aria-label="Learn more about Hourly Mediation"
          >
            Learn more
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </li>

        <li class="landing-card">
          <div class="landing-card-head">
            <span class="landing-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                <path d="M10 9H8" />
                <path d="M16 13H8" />
                <path d="M16 17H8" />
              </svg>
            </span>
            <h2 class="landing-card-title display">Parenting Plan Preparation</h2>
          </div>
          <p class="landing-card-price smallcaps">$400 flat</p>
          <p class="landing-card-body">
            A customized Parenting Plan tailored to your family's
            schedule, structure, and needs. Delivered in a clear,
            court-ready format.
          </p>
          <a
            href="/services/parenting-plan"
            class="landing-card-link"
            aria-label="Learn more about Parenting Plan Preparation"
          >
            Learn more
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </li>

        <li class="landing-card">
          <div class="landing-card-head">
            <span class="landing-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 7h-3a2 2 0 0 1-2-2V2" />
                <path d="M9 18a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h7l4 4v10a2 2 0 0 1-2 2Z" />
                <path d="M3 7.6v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8" />
              </svg>
            </span>
            <h2 class="landing-card-title display">Turn-Key Court Packet</h2>
          </div>
          <p class="landing-card-price smallcaps">$600 flat</p>
          <p class="landing-card-body">
            A complete, organized set of family-law documents,
            assembled into a filing-ready packet with notarization
            where applicable.
          </p>
          <a
            href="/services/court-packet"
            class="landing-card-link"
            aria-label="Learn more about the Turn-Key Court Packet"
          >
            Learn more
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </li>

      </ul>
    </div>
  </section>

  <!-- ========================== BOOK ========================== -->
  <section class="landing-book">
    <div class="container landing-book-inner">
      <h2 class="display landing-book-title">
        Book a <span class="display-italic">free</span> 15-minute consultation.
      </h2>
      <p class="lede landing-book-lede">
        Pick a time below. I'll review your situation and outline the
        next steps that fit your case. Or reach out to me directly at
        <a class="link-underline" href={`mailto:${email}`}>{email}</a>
        or
        <a
          class="link-underline"
          href={`tel:${phoneTel}`}
          aria-label={`Call ${phoneDigits}`}
        >{phoneVanity}</a>.
      </p>

      <p class="landing-pay-strip">
        Already agreed on a Parenting Plan or Turn-Key Court Packet service?
        <a class="btn btn-primary landing-pay-btn" href="/pay">
          Pay here
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </p>

      <div
        class="calendly-inline-widget"
        data-url={calendlyUrl}
      ></div>
    </div>
  </section>

  <script
    is:inline
    type="text/javascript"
    src="https://assets.calendly.com/assets/external/widget.js"
    async
  ></script>
</BaseLayout>

<style>
  /* ============================================================
     HEADER (photo hero, same pattern as /book)
     ============================================================ */
  .landing-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/justice_globe.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .landing-header::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .landing-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .landing-header .kicker {
    color: var(--color-gold);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .landing-header .kicker-dot {
    background: var(--color-gold);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-gold) 25%, transparent);
  }
  .landing-title {
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-cream);
    margin-top: 1rem;
    letter-spacing: -0.025em;
    max-width: 22ch;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .landing-title .display-italic {
    color: var(--color-gold);
    font-weight: 400;
  }
  .landing-header .lede {
    margin-top: 1.5rem;
    max-width: none;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }

  /* ============================================================
     SERVICES (three-column cards)
     ============================================================ */
  .landing-services {
    background: var(--color-cream-warm);
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-divider);
    position: relative;
  }
  .landing-services::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 35%, var(--color-gold) 65%, transparent);
    opacity: 0.45;
  }
  .landing-services-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }
  .landing-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--color-gold);
    position: relative;
  }
  .landing-card-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.1rem;
  }
  .landing-card-icon {
    display: inline-flex;
    color: var(--color-gold-deep);
    flex-shrink: 0;
  }
  .landing-card-title {
    font-size: var(--step-2);
    line-height: 1.1;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    font-weight: 400;
  }
  .landing-card-price {
    font-size: 1.55rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.14em;
    margin-top: 0;
  }
  .landing-card-body {
    font-family: var(--font-body);
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .landing-card-link {
    margin-top: auto;
    padding-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-gold-deep);
    transition: color 0.2s, gap 0.25s var(--ease-out);
  }
  .landing-card-link .arrow {
    transition: transform 0.25s var(--ease-out);
  }
  .landing-card-link:hover {
    color: var(--color-navy);
    gap: 0.75rem;
  }
  .landing-card-link:hover .arrow {
    transform: translateX(3px);
  }

  /* Below 720px, 3 across gets too tight to read comfortably. Stack
     to single column so each card can keep desktop typography. */
  @media (max-width: 720px) {
    .landing-services-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }

  /* Title — phone-only shrink so it doesn't blow past the viewport
     and break across four lines. */
  @media (max-width: 600px) {
    .landing-title {
      font-size: clamp(1.55rem, 1.2rem + 2.8vw, 2.5rem);
      max-width: 100%;
    }
  }

  /* ============================================================
     BOOK (Calendly embed)
     ============================================================ */
  .landing-book {
    padding-block: var(--space-xl) var(--space-2xl);
    background: var(--color-cream);
  }
  .landing-book-title {
    font-size: var(--step-4);
    line-height: 1.05;
    color: var(--color-navy);
    letter-spacing: -0.02em;
    max-width: 22ch;
    font-weight: 400;
  }
  .landing-book-title .display-italic { color: var(--color-gold-deep); }
  .landing-book-lede {
    margin-top: 1rem;
    max-width: 56ch;
    color: var(--color-ink-soft);
  }
  .landing-pay-strip {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-ink-soft);
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-divider);
  }
  .landing-pay-btn {
    padding: 0.6rem 1.2rem;
    font-size: 0.9rem;
    border-color: var(--color-gold);
  }
  .calendly-inline-widget {
    margin-top: var(--space-lg);
    min-width: 320px;
    height: clamp(720px, 90vh, 1100px);
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }
</style>
