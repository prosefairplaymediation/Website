---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl = "https://calendly.com/prosefairplaymediation-info/free-consultation";
---

<BaseLayout
  title="Book a Consultation · Pro Se Fair Play Mediation"
  description="Schedule a free 15-minute consultation to determine whether mediation or document preparation is appropriate for your case."
>
  <!-- ========================== HEADER ========================== -->
  <header class="book-header">
    <div class="container book-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        Book · Free Consultation
      </p>
      <h1 class="display book-title reveal reveal-d2">
        Schedule a <span class="display-italic">15-minute</span> consultation<span class="display-italic">.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        A short, no-cost conversation to understand your situation and
        determine whether mediation or document preparation is appropriate
        for your case. No legal advice — just clarity on what's possible
        and what comes next.
      </p>

    </div>
  </header>

  <!-- ========================== SUPPORT ========================== -->
  <section class="book-support">
    <div class="container book-support-inner">
      <div class="support-grid">
        <article class="support-card">
          <div class="support-head">
            <span class="support-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </span>
            <h2 class="support-title display">Evenings &amp; Weekends</h2>
          </div>
          <p class="support-body">
            Appointments available when traditional hours don't work for you.
          </p>
          <p class="support-note">Designed for working parents and busy professionals.</p>
        </article>

        <article class="support-card">
          <div class="support-head">
            <span class="support-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="m11 17 2 2a1 1 0 1 0 3-3" />
                <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" />
                <path d="m21 3 1 11h-2" />
                <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" />
                <path d="M3 4h8" />
              </svg>
            </span>
            <h2 class="support-title display">Mediation with Care</h2>
          </div>
          <p class="support-body">
            A calm, respectful space to communicate and reach solutions together.
          </p>
        </article>

        <article class="support-card">
          <div class="support-head">
            <span class="support-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                <path d="M10 9H8" />
                <path d="M16 13H8" />
                <path d="M16 17H8" />
              </svg>
            </span>
            <h2 class="support-title display">Document Preparation</h2>
          </div>
          <p class="support-body">
            Clear, accurate documents prepared to help you move forward with confidence.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ========================== CALENDLY EMBED ========================== -->
  <section class="book-embed-section">
    <div class="container">
      <div
        class="calendly-inline-widget"
        data-url={calendlyUrl}
      ></div>
    </div>
  </section>

  <!-- Calendly widget loader — keep external, do not bundle -->
  <script
    is:inline
    type="text/javascript"
    src="https://assets.calendly.com/assets/external/widget.js"
    async
  ></script>

  <!-- ========================== DISCLAIMER ========================== -->

</BaseLayout>

<style>
  /* ============================================================
     HEADER
     ============================================================ */
  .book-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/justice_globe.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .book-header::after {
    /* Bottom fade so the section eases into the cream below */
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .book-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .book-header .kicker {
    color: var(--color-gold);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .book-header .kicker-dot { background: var(--color-gold); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-gold) 25%, transparent); }
  .book-title {
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-cream);
    margin-top: 1rem;
    letter-spacing: -0.025em;
    max-width: 22ch;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .book-title .display-italic {
    color: var(--color-gold);
    font-weight: 400;
  }
  .book-header .lede {
    margin-top: 1.5rem;
    max-width: 56ch;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }

  /* ============================================================
     SUPPORT — three-column "support that works around your life"
     ============================================================ */
  .book-support {
    background: var(--color-cream-warm);
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-divider);
    position: relative;
  }
  .book-support::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 35%, var(--color-gold) 65%, transparent);
    opacity: 0.45;
  }
  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }
  .support-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 2px solid var(--color-gold);
    position: relative;
  }
  .support-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }
  .support-icon {
    display: inline-flex;
    color: var(--color-gold-deep);
    flex-shrink: 0;
  }
  .support-title {
    font-size: var(--step-2);
    line-height: 1.1;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    font-weight: 400;
  }
  .support-body {
    font-family: var(--font-body);
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .support-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.45;
    color: var(--color-gold-deep);
    margin-top: 0.15rem;
  }

  /* ============================================================
     CALENDLY EMBED
     ============================================================ */
  .book-embed-section {
    padding-block: var(--space-xl) var(--space-2xl);
    background: var(--color-cream);
  }
  .calendly-inline-widget {
    min-width: 320px;
    height: clamp(720px, 90vh, 1100px);
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }

  /* ============================================================
     DISCLAIMER
     ============================================================ */
  .book-disclaimer {
    padding-block: var(--space-lg) var(--space-3xl);
    background: var(--color-cream);
  }
  .rule-gold-left { margin-bottom: 1.25rem; }
  .disclaimer-label {
    font-size: 0.7rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
    margin-bottom: 0.85rem;
    display: block;
  }
  .disclaimer-body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 70ch;
  }
  .disclaimer-body strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  /* Below 720px, 3 across gets too tight to read comfortably. Stack
     to single column so each card can keep desktop typography. */
  @media (max-width: 720px) {
    .support-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
