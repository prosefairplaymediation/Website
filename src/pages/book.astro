---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl = "https://calendly.com/prosefairplaymediation-info/free-consultation";
---

<BaseLayout
  title="Book a Consultation · Pro Se Fair Play Mediation"
  description="Schedule a free 15-minute consultation to determine whether mediation or document preparation is appropriate for your case."
>
  <!-- ========================== HEADER ========================== -->
  <header class="book-header">
    <div class="container book-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        Book · Free Consultation
      </p>
      <h1 class="display book-title reveal reveal-d2">
        Schedule a <span class="display-italic">15-minute</span> consultation.
      </h1>
      <p class="lede reveal reveal-d3">
        A short, no-cost conversation to understand your situation and
        determine whether mediation or document preparation is appropriate
        for your case. No legal advice — just clarity on what's possible
        and what comes next.
      </p>

      <div class="expectations reveal reveal-d4">
        <div class="expect">
          <span class="expect-num display">01</span>
          <p class="expect-body">Pick a time that works.</p>
        </div>
        <div class="expect">
          <span class="expect-num display">02</span>
          <p class="expect-body">Tell us briefly what's going on.</p>
        </div>
        <div class="expect">
          <span class="expect-num display">03</span>
          <p class="expect-body">We meet on Google Meet for 15 minutes.</p>
        </div>
      </div>
    </div>
  </header>

  <!-- ========================== CALENDLY EMBED ========================== -->
  <section class="book-embed-section">
    <div class="container">
      <div
        class="calendly-inline-widget"
        data-url={calendlyUrl}
      ></div>
    </div>
  </section>

  <!-- Calendly widget loader — keep external, do not bundle -->
  <script
    is:inline
    type="text/javascript"
    src="https://assets.calendly.com/assets/external/widget.js"
    async
  ></script>

  <!-- ========================== DISCLAIMER ========================== -->

</BaseLayout>

<style>
  /* ============================================================
     HEADER
     ============================================================ */
  .book-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/justice_globe.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .book-header::after {
    /* Bottom fade so the section eases into the cream below */
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .book-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .book-header .kicker { color: var(--color-gold); }
  .book-header .kicker-dot { background: var(--color-gold); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-gold) 25%, transparent); }
  .book-title {
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-cream);
    margin-top: 1rem;
    letter-spacing: -0.025em;
    max-width: 22ch;
    font-weight: 400;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }
  .book-title .display-italic {
    color: var(--color-gold);
    font-weight: 400;
  }
  .book-header .lede {
    margin-top: 1.5rem;
    max-width: 56ch;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
  }

  .expectations {
    margin-top: 2.25rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 25%, transparent);
    position: relative;
  }
  .expectations::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 3rem; height: 1px;
    background: var(--color-gold);
  }
  .expect { display: flex; gap: 0.85rem; align-items: baseline; }
  .expect-num {
    font-size: 1.1rem;
    color: var(--color-gold);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
    flex-shrink: 0;
    font-variation-settings: "opsz" 24;
  }
  .expect-body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
  }

  /* ============================================================
     CALENDLY EMBED
     ============================================================ */
  .book-embed-section {
    padding-block: var(--space-xl) var(--space-2xl);
    background: var(--color-cream);
  }
  .calendly-inline-widget {
    min-width: 320px;
    height: clamp(720px, 90vh, 1100px);
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }

  /* ============================================================
     DISCLAIMER
     ============================================================ */
  .book-disclaimer {
    padding-block: var(--space-lg) var(--space-3xl);
    background: var(--color-cream);
  }
  .rule-gold-left { margin-bottom: 1.25rem; }
  .disclaimer-label {
    font-size: 0.7rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
    margin-bottom: 0.85rem;
    display: block;
  }
  .disclaimer-body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 70ch;
  }
  .disclaimer-body strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 720px) {
    .expectations {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }
</style>
