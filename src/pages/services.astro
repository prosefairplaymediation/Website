---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    id: "mediation",
    title: "Hourly Mediation",
    price: "$600 / hour",
    priceSub: "Combined rate, commonly split evenly between parties",
    meta: ["Two-hour minimum per session", "Half-day and full-day available", "Same-day availability possible", "Conducted via Zoom, confidential"],
    body: [
      "A neutral, structured, confidential process designed to help both parties work toward a mutually acceptable resolution — without a judge imposing one. The mediator sets the table, keeps the conversation productive, and helps the parties surface workable options.",
      "Mediation is often faster, quieter, and less expensive than litigating to a final hearing. When an agreement is reached, we prepare a Memorandum of Understanding summarizing the terms.",
    ],
    matters: {
      label: "Common matters",
      items: [
        "Parenting plans",
        "Time-sharing disputes",
        "Decision-making authority",
        "Child support",
        "Post-judgment modifications",
        "Uncontested matters",
        "Multi-session high-conflict",
      ],
    },
    note:
      "All mediation services are performed in accordance with the Florida Supreme Court Rules for Certified and Court-Appointed Mediators and Chapter 44 Florida Statutes.",
  },
  {
    id: "parenting-plan",
    title: "Parenting Plan Preparation",
    price: "$600 flat",
    priceSub: "Document preparation only — no hearing required",
    meta: ["Customized to your family's schedule", "Delivered in court-ready format", "Based on information provided by the parties"],
    body: [
      "A customized Parenting Plan tailored to your family's specific needs, schedule, and structure. We prepare the document from the information you and the other party provide — designed to reflect time-sharing, decision-making, and parental responsibilities.",
      "Delivered in a clear, court-ready format so it is ready for filing.",
    ],
    matters: {
      label: "What's included",
      items: [
        "Time-sharing schedule",
        "Decision-making framework",
        "Holidays and school breaks",
        "Communication protocols",
        "Transportation and exchanges",
      ],
    },
    note:
      "This service is limited to document preparation. The mediator does not provide legal advice, legal strategy, or representation.",
  },
  {
    id: "court-packet",
    title: "Turn-Key Court Packet",
    price: "$800 flat",
    priceSub: "Includes up to two revisions",
    meta: ["Formatted and filing-ready", "Notarization where applicable", "Designed for final hearing preparation"],
    body: [
      "A streamlined, organized set of completed documents in preparation for a final hearing. We complete the required court forms from the information you provide, assemble a comprehensive packet, and format it for filing readiness.",
      "The goal is simple: a fully prepared, filing-ready packet so you can proceed efficiently through the court process.",
    ],
    matters: {
      label: "Includes",
      items: [
        "Completion of required court forms",
        "Assembly of a comprehensive court packet",
        "Formatting for filing readiness",
        "Notarization of applicable documents",
        "Up to two rounds of revisions",
      ],
    },
    note:
      "Document preparation only. We do not file documents with the court on your behalf, and we do not appear in court.",
  },
];

const terms = [
  "Payment is required in full prior to scheduling. Time is not reserved until payment is received.",
  "Two-hour minimum applies to all mediation sessions.",
  "24-hour notice required for cancellations or rescheduling.",
  "Revisions beyond the included scope may be subject to additional fees.",
];
---

<BaseLayout
  title="Services · Pro Se Fair Play Mediation"
  description="Family law mediation and document preparation services for self-represented parties in Florida. Hourly mediation, parenting plans, and turn-key court packets at transparent flat fees."
>
  <!-- ========================== PAGE HEADER ========================== -->
  <header class="page-header">
    <div class="container page-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        Services &amp; Pricing
      </p>
      <h1 class="display page-title reveal reveal-d2">
        Transparent, upfront <span class="display-italic">pricing.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        Three services, clearly priced. Family law mediation and document
        preparation for self-represented parties in Florida — structured
        to be efficient, neutral, and resolution-focused.
      </p>

      <nav class="anchor-nav reveal reveal-d4" aria-label="Services on this page">
        {services.map((s) => (
          <a href={`#${s.id}`} class="anchor-link">
            <span class="anchor-title">{s.title}</span>
          </a>
        ))}
      </nav>
    </div>
  </header>

  <!-- ========================== SERVICES ========================== -->
  {services.map((s, idx) => (
    <section id={s.id} class={`service-section ${idx % 2 === 1 ? "alt" : ""}`}>
      <div class="container service-layout">
        <aside class="service-aside">
          <p class="kicker service-aside-kicker">
            <span class="kicker-dot" aria-hidden="true"></span>
            Service
          </p>
          <h2 class="display service-section-title">{s.title}</h2>

          <div class="price-block">
            <p class="price-amount display">{s.price}</p>
            <p class="price-sub">{s.priceSub}</p>
          </div>

          <ul class="service-meta">
            {s.meta.map((m) => (
              <li>
                <svg class="check" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                  <path d="M3 8.5 L6.5 12 L13 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {m}
              </li>
            ))}
          </ul>
        </aside>

        <div class="service-content">
          {s.body.map((p, i) => (
            <p class={`service-p ${i === 0 ? "dropcap" : ""}`}>{p}</p>
          ))}

          <div class="matters">
            <p class="matters-label smallcaps">{s.matters.label}</p>
            <ul class="matters-list">
              {s.matters.items.map((item) => (
                <li><span class="matter-dot" aria-hidden="true"></span>{item}</li>
              ))}
            </ul>
          </div>

          <p class="service-note">
            <strong>Note.</strong> {s.note}
          </p>

          <div class="service-ctas">
            <a class="btn btn-primary" href="/book">
              Book This Service
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="link-underline" href="/contact">
              Questions first?
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ========================== PAYMENT TERMS ========================== -->
  <section class="section terms-section">
    <div class="container-narrow">
      <header class="section-head-simple">
        <p class="kicker">Payment &amp; Scheduling</p>
        <h2 class="display terms-title">Clear terms. No surprises.</h2>
      </header>

      <ol class="terms-list">
        {terms.map((t, i) => (
          <li class="term-item">
            <span class="term-num display">{String(i + 1).padStart(2, "0")}</span>
            <p class="term-body">{t}</p>
          </li>
        ))}
      </ol>

      <p class="term-disclosure">
        Pro Se Fair Play Mediation operates strictly as a neutral mediation and
        document preparation service. The mediator does not represent either
        party, does not provide legal advice or legal opinions, does not file
        documents with the court on behalf of any party, and does not appear
        in court or act as legal counsel in any capacity. Parties are strongly
        encouraged to seek independent legal counsel to review any documents
        prior to filing.
      </p>
    </div>
  </section>

  <!-- ========================== CTA ========================== -->
  <section class="cta">
    <div class="container-narrow cta-inner">
      <p class="kicker cta-kicker">Ready when you are</p>
      <h2 class="display cta-title">
        Schedule a consultation.
      </h2>
      <p class="lede cta-lede">
        We'll review your situation, determine whether mediation or document
        preparation is appropriate, and — if so — quote a clear scope and
        flat fee where possible.
      </p>
      <div class="cta-actions">
        <a class="btn btn-primary cta-btn" href="/book">
          Schedule a Time
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="link-underline cta-link" href="/faq">
          See FAQ first
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     PAGE HEADER
     ============================================================ */
  .page-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 2rem, 7rem) clamp(3rem, 4vw + 1rem, 5rem);
    background:
      radial-gradient(ellipse at 85% 20%, rgba(196, 154, 75, 0.1), transparent 55%),
      var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
    overflow: hidden;
  }
  .page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(27, 45, 90, 0.035) 1px, transparent 1px);
    background-size: 7rem 100%;
    mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    pointer-events: none;
  }
  .page-header-inner { position: relative; }
  .page-title {
    font-size: var(--step-5);
    line-height: 1;
    color: var(--color-navy);
    margin-top: 1.25rem;
    letter-spacing: -0.025em;
    max-width: 20ch;
  }
  .page-header .lede {
    margin-top: 1.5rem;
    max-width: 58ch;
  }

  /* Anchor nav */
  .anchor-nav {
    margin-top: 2.75rem;
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-divider);
    padding-top: 1.25rem;
  }
  .anchor-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.5rem 1.35rem 0.5rem 0;
    margin-right: 1.35rem;
    border-right: 1px solid var(--color-divider);
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    transition: color 0.25s;
  }
  .anchor-link:last-child { border-right: 0; margin-right: 0; }
  .anchor-num {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 48;
    color: var(--color-gold);
    font-size: 0.95rem;
  }
  .anchor-link:hover { color: var(--color-navy); }
  .anchor-link:hover .anchor-num { color: var(--color-gold-deep); }

  /* ============================================================
     SERVICE SECTION (repeated)
     ============================================================ */
  .service-section {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-divider);
    scroll-margin-top: 5rem;
  }
  .service-section.alt {
    background: var(--color-cream-warm);
  }

  .service-layout {
    display: grid;
    grid-template-columns: 22rem 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Aside — fixed title + price block */
  .service-aside { position: sticky; top: 6rem; }
  .service-aside-numeral {
    font-size: var(--step-5);
    color: var(--color-gold);
    line-height: 0.85;
    letter-spacing: -0.03em;
    font-weight: 300;
    margin-bottom: 1rem;
  }
  .service-aside-kicker { margin-bottom: 0.75rem; }
  .service-section-title {
    font-size: var(--step-3);
    color: var(--color-navy);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 1.5rem;
  }

  .price-block {
    padding: 1rem 0 1.25rem;
    border-block: 1px solid var(--color-divider);
    position: relative;
  }
  .price-block::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 3rem; height: 1px;
    background: var(--color-gold);
  }
  .price-amount {
    font-size: var(--step-3);
    color: var(--color-navy);
    letter-spacing: -0.01em;
    line-height: 1;
    font-variation-settings: "opsz" 72;
  }
  .price-sub {
    margin-top: 0.45rem;
    font-size: 0.875rem;
    color: var(--color-slate);
    font-style: italic;
    line-height: 1.4;
  }

  .service-meta {
    list-style: none;
    padding: 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .service-meta li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    line-height: 1.45;
  }
  .service-meta .check {
    color: var(--color-gold-deep);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  /* Content — the article body */
  .service-content { max-width: 52ch; }
  .service-p {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.65;
    color: var(--color-ink-soft);
  }
  .service-p + .service-p { margin-top: 1.25rem; }

  .matters {
    margin-top: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-divider);
    position: relative;
  }
  .matters::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 2rem; height: 1px;
    background: var(--color-gold);
  }
  .matters-label {
    font-size: 0.72rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
    display: block;
    margin-bottom: 1rem;
  }
  .matters-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 1.5rem;
    row-gap: 0.5rem;
  }
  .matters-list li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.95rem;
    color: var(--color-ink-soft);
  }
  .matter-dot {
    width: 5px; height: 5px;
    background: var(--color-gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .service-note {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    border-left: 2px solid var(--color-gold);
    background: color-mix(in srgb, var(--color-cream-warm) 55%, transparent);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }
  .service-note strong {
    color: var(--color-navy);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .service-ctas {
    margin-top: 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ============================================================
     TERMS SECTION
     ============================================================ */
  .terms-section {
    padding-block: var(--space-3xl);
    background: var(--color-cream);
  }
  .section-head-simple {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .terms-title {
    margin-top: 0.75rem;
    font-size: var(--step-4);
    color: var(--color-navy);
    letter-spacing: -0.015em;
  }
  .terms-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2rem;
    counter-reset: none;
    margin-bottom: var(--space-xl);
  }
  .term-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
    position: relative;
  }
  .term-item::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 2rem; height: 1px;
    background: var(--color-gold);
  }
  .term-num {
    font-size: 1.15rem;
    color: var(--color-gold-deep);
    font-weight: 500;
    line-height: 1;
    padding-top: 0.15rem;
  }
  .term-body {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .term-disclosure {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--color-slate);
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--color-divider);
    font-style: italic;
  }

  /* ============================================================
     CTA (inherits from global)
     ============================================================ */
  .cta {
    position: relative;
    padding-block: var(--space-3xl);
    background:
      radial-gradient(ellipse at 80% 50%, rgba(196, 154, 75, 0.14), transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(196, 154, 75, 0.08), transparent 45%),
      var(--color-cream-warm);
    color: var(--color-ink);
    overflow: hidden;
    border-top: 1px solid var(--color-divider);
  }
  .cta::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.7;
  }
  .cta-kicker { color: var(--color-gold-deep); }
  .cta-title {
    margin-block: 1rem 1.5rem;
    font-size: var(--step-5);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--color-navy);
    max-width: 20ch;
  }
  .cta-title .display-italic { color: var(--color-gold-deep); }
  .cta-lede {
    color: var(--color-ink-soft);
    max-width: 56ch;
  }
  .cta-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    background: var(--color-navy);
    color: var(--color-cream);
    border-color: var(--color-navy);
  }
  .cta-btn:hover {
    background: var(--color-navy-deep);
    color: var(--color-cream);
    border-color: var(--color-gold);
  }
  .cta-link {
    color: var(--color-navy);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
  }
  .cta-link:hover { color: var(--color-gold-deep); }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 960px) {
    .service-layout { grid-template-columns: 1fr; gap: var(--space-xl); }
    .service-aside { position: static; }
    .matters-list { grid-template-columns: 1fr; }
    .terms-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .anchor-nav { gap: 0.5rem; }
    .anchor-link {
      border: 1px solid var(--color-divider);
      padding: 0.5rem 0.75rem;
      margin: 0;
      border-radius: 2px;
    }
    .anchor-link:last-child { border-right: 1px solid var(--color-divider); }
  }
</style>
