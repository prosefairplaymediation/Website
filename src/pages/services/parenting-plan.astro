---
import BaseLayout from "../../layouts/BaseLayout.astro";

const facts = [
  { label: "Fee", value: "$600 flat" },
  { label: "Format", value: "Document only" },
  { label: "Output", value: "Court-ready" },
  { label: "Includes", value: "Customized to your family" },
];

const includes = [
  "Time-sharing schedule designed around your family's actual life",
  "Decision-making framework (education, healthcare, religion, etc.)",
  "Holidays and school breaks",
  "Communication protocols between parents",
  "Transportation and exchange arrangements",
  "Delivered in clear, court-ready format",
];

---

<BaseLayout
  title="Parenting Plan Preparation · Pro Se Fair Play Mediation"
  description="Custom Parenting Plan preparation for self-represented parties in Florida. $600 flat fee, court-ready format, document preparation only."
>
  <!-- ========================== HEADER ========================== -->
  <header class="svc-header">
    <div class="container svc-header-inner">
      <h1 class="display svc-title reveal reveal-d2">
        Parenting Plan <span class="display-italic">Preparation</span>.
      </h1>
      <p class="lede reveal reveal-d3">
        A customized Parenting Plan tailored to your family's specific
        schedule, structure, and needs — drafted from the information you
        and the other party provide, delivered in a clear, court-ready
        format.
      </p>
      <a class="btn btn-primary svc-header-cta reveal reveal-d4" href="/book">
        Book a Free Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </header>

  <!-- ========================== AT-A-GLANCE ========================== -->
  <section class="svc-facts">
    <div class="container">
      <dl class="facts-grid">
        {facts.map((f) => (
          <div class="fact">
            <dt class="fact-label smallcaps">{f.label}</dt>
            <dd class="fact-value display">{f.value}</dd>
          </div>
        ))}
      </dl>
      <p class="facts-note">
        This service prepares <strong>only the Parenting Plan</strong>. It
        does not include the other Florida Supreme Court forms required to
        file your case. If you want a complete filing-ready packet, see the{" "}
        <a class="link-underline" href="/services/court-packet">Turn-Key Court Packet</a>.
      </p>
    </div>
  </section>

  <!-- ========================== OVERVIEW ========================== -->
  <section class="svc-section">
    <div class="container-narrow">
      <p class="kicker">Overview</p>
      <h2 class="display svc-h2">A real plan for a real family.</h2>

      <div class="svc-prose">
        <p class="dropcap">
          A Parenting Plan is the document that lays out how parents will
          share time, raise their children, and make decisions together
          after a separation. In Florida, it's required in most family-law
          matters involving minor children.
        </p>
        <p>
          Generic templates rarely fit real families. We work from the
          schedules, priorities, and constraints you and the other party
          actually have — and structure the plan to reflect that. Time
          arrangements, decision-making authority, communication
          expectations, and the small logistics that make plans hold up
          over time.
        </p>
        <p>
          Delivered in a clear, court-ready format that you can take to
          filing.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================== WHAT'S INCLUDED ========================== -->
  <section class="svc-section svc-section-alt">
    <div class="container-narrow">
      <p class="kicker">What's included</p>
      <h2 class="display svc-h2">In the prepared plan.</h2>

      <ul class="includes-list">
        {includes.map((item) => (
          <li>
            <svg class="check" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
              <path d="M3 8.5 L6.5 12 L13 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ========================== CTA ========================== -->
  <section class="cta">
    <div class="container-narrow cta-inner">
      <p class="kicker cta-kicker">Start the conversation</p>
      <h2 class="display cta-title">
        Begin with a <span class="display-italic">free</span> 15-minute consultation.
      </h2>
      <p class="lede cta-lede">
        We'll review your situation, confirm a Parenting Plan is the right
        scope, and outline what we'll need from you to prepare it — at no
        cost.
      </p>
      <div class="cta-actions">
        <a class="btn btn-primary cta-btn" href="/book">
          Book a Free Consultation
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Identical pattern to hourly-mediation.astro for visual consistency ---- */
  .svc-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/documents2.jpeg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .svc-header::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .svc-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .svc-header .kicker { color: var(--color-gold); }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-gold); font-weight: 600; transition: color 0.2s; }
  .back-link:hover { color: var(--color-cream); }
  .arrow-left { transition: transform 0.3s var(--ease-out); }
  .back-link:hover .arrow-left { transform: translateX(-3px); }
  .kicker-sep { color: color-mix(in srgb, var(--color-cream) 30%, transparent); margin-inline: 0.4rem; }
  .svc-title { margin-top: 1rem; font-size: var(--step-5); line-height: 1.02; color: var(--color-cream); letter-spacing: -0.025em; max-width: 22ch; font-weight: 400; text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45); }
  .svc-title .display-italic { color: var(--color-gold); font-weight: 400; }
  .svc-header .lede { margin-top: 1.5rem; max-width: 60ch; color: color-mix(in srgb, var(--color-cream) 85%, transparent); }
  .svc-header-cta { margin-top: 1.75rem; }

  .svc-facts { padding-block: var(--space-xl); background: var(--color-cream); border-bottom: 1px solid var(--color-divider); }
  .facts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem 2rem; margin: 0; }
  .fact { display: flex; flex-direction: column; gap: 0.35rem; }
  .fact-label { font-size: 0.7rem; color: var(--color-gold-deep); font-weight: 700; letter-spacing: 0.24em; }
  .fact-value { margin: 0; font-size: 1.15rem; color: var(--color-navy); font-variation-settings: "opsz" 24; line-height: 1.2; }
  .facts-note { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-divider); font-family: var(--font-body); font-size: 0.92rem; line-height: 1.6; color: var(--color-ink-soft); max-width: 70ch; font-style: italic; }
  .facts-note strong { color: var(--color-navy); font-weight: 600; font-style: normal; }
  .facts-note a { font-style: normal; }

  .svc-section { padding-block: var(--space-2xl); }
  .svc-section-alt { background: var(--color-cream-warm); }
  .svc-h2 { margin-block: 0.75rem 1.5rem; font-size: var(--step-3); color: var(--color-navy); line-height: 1.05; letter-spacing: -0.015em; max-width: 22ch; }
  .svc-prose { font-family: var(--font-body); font-size: var(--step-1); line-height: 1.7; color: var(--color-ink-soft); max-width: 60ch; }
  .svc-prose p + p { margin-top: 1.25rem; }
  .svc-prose strong { color: var(--color-navy); font-weight: 500; }

  .includes-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; max-width: 60ch; }
  .includes-list li { display: grid; grid-template-columns: auto 1fr; gap: 0.85rem; align-items: baseline; font-size: 1rem; line-height: 1.55; color: var(--color-ink-soft); }
  .includes-list .check { color: var(--color-gold-deep); margin-top: 0.25rem; }

  .cta { position: relative; padding-block: var(--space-3xl); background: var(--color-cream); color: var(--color-ink); overflow: hidden; border-top: 1px solid var(--color-divider); }
  .cta::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 1px; background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent); opacity: 0.7; }
  .cta-kicker { color: var(--color-gold-deep); }
  .cta-title { margin-block: 1rem 1.5rem; font-size: var(--step-4); line-height: 1.05; letter-spacing: -0.02em; color: var(--color-navy); max-width: 22ch; }
  .cta-title .display-italic { color: var(--color-gold-deep); }
  .cta-lede { color: var(--color-ink-soft); max-width: 56ch; }
  .cta-actions { margin-top: 2rem; display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
  .cta-btn { background: var(--color-navy); color: var(--color-cream); border-color: var(--color-navy); }
  .cta-btn:hover { background: var(--color-navy-deep); color: var(--color-cream); border-color: var(--color-gold); }
  .cta-link { color: var(--color-navy); background-image: linear-gradient(var(--color-gold), var(--color-gold)); }
  .cta-link:hover { color: var(--color-gold-deep); }

  @media (max-width: 720px) {
    .facts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .facts-grid { grid-template-columns: 1fr; }
  }
</style>
