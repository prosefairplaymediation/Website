---
import BaseLayout from "../../layouts/BaseLayout.astro";

const facts = [
  { label: "Fee", value: "$400 flat" },
  { label: "Format", value: "Document only" },
  { label: "Output", value: "Court-ready" },
  { label: "Includes", value: "Customized to your family" },
];

---

<BaseLayout
  title="Parenting Plan Preparation · Pro Se Fair Play Mediation"
  description="Custom Parenting Plan preparation for self-represented parties in Florida. $400 flat fee, court-ready format, document preparation only."
>
  <!-- ========================== HEADER ========================== -->
  <header class="svc-header">
    <div class="container svc-header-inner">
      <h1 class="display svc-title reveal reveal-d2">
        Parenting Plan <span class="display-italic">Preparation</span><span class="display-italic">.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        A customized Parenting Plan tailored to your family's specific
        schedule, structure, and needs — drafted from the information you
        and the other party provide, delivered in a clear, court-ready
        format.
      </p>
      <div class="svc-header-ctas reveal reveal-d4">
        <a class="btn btn-primary svc-header-cta" href="/book">
          Book a Free Consultation
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a
          class="btn svc-header-cta svc-header-cta-pay"
          href="/pay"
          onclick="if(window.gtag)gtag('event','pay_intent_click',{source:'parenting_plan_page',product:'parenting_plan'})"
        >
          Pay for a Parenting Plan
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </header>

  <!-- ========================== AT-A-GLANCE ========================== -->
  <section class="svc-facts">
    <div class="container">
      <dl class="facts-grid">
        {facts.map((f) => (
          <div class="fact">
            <dt class="fact-label smallcaps">{f.label}</dt>
            <dd class="fact-value display">{f.value}</dd>
          </div>
        ))}
      </dl>
      <p class="facts-note">
        This service prepares <strong>only the Parenting Plan</strong>. It
        does not include the other Florida Supreme Court forms required to
        file your case. If you want a complete filing-ready packet, see the{" "}
        <a class="link-underline" href="/services/court-packet">Turn-Key Court Packet</a>.
      </p>
    </div>
  </section>

  <!-- ========================== PROSE ========================== -->
  <section class="svc-section svc-section-alt">
    <div class="container-narrow">
      <div class="svc-prose">
        <p>
          For parents who need assistance preparing only a Parenting
          Plan, I provide professionally customized parenting plans
          tailored to the unique needs and schedules of each family.
          These plans may address important issues such as
          time-sharing schedules, holidays, transportation, parental
          responsibility, communication guidelines, and child support
          provisions.
        </p>
        <p>
          This service is limited strictly to the preparation of the
          Parenting Plan document itself and does not include
          additional court forms or filing services. Clients are
          responsible for filing the completed Parenting Plan with the
          court independently.
        </p>
        <p>
          Parents will need the appropriate forms found here to complete the package once
          the Parenting Plan is created:
          <a
            class="link-underline"
            href="https://www.flcourts.gov/Services/Family-Courts/domestic-relations-court-resources/family-law-forms"
            target="_blank"
            rel="noopener noreferrer"
          >Florida Courts Family Law Forms</a>.
        </p>
        <p>
          Online notarization of relevant documents may be added for a
          small $10 fee, if needed. See{" "}
          <a class="link-underline" href="/services/notary">Online Notary Services</a>{" "}
          for details.
        </p>
        <p>
          Every Parenting Plan is prepared with close attention to
          structure, clarity, organization, and procedural detail to
          help families create a practical framework centered around
          the best interests of their children.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================== CTA ========================== -->
  <section class="cta">
    <div class="container-narrow cta-inner">
      <p class="kicker cta-kicker">Start the conversation</p>
      <h2 class="display cta-title">
        Begin with a <span class="display-italic">free</span> 15-minute consultation.
      </h2>
      <p class="lede cta-lede">
        This consultation lets me discuss your case and determine which
        Parenting Plan is right for your family.
      </p>
      <div class="cta-actions">
        <a class="btn btn-primary cta-btn" href="/book">
          Book a Free Consultation
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================== REFUND POLICY ========================== -->
  <section class="refund">
    <div class="container-narrow">
      <p class="refund-kicker smallcaps">Document Preparation</p>
      <h2 class="display refund-title">Refund Policy</h2>
      <div class="refund-body">
        <p>
          Document preparation services are customized for each client
          and matter. Because of the time, attention, and preparation
          involved, refunds are available prior to the start of
          drafting or document preparation work.
        </p>
        <p>
          Once work has begun, payments may be applied as a credit
          toward ongoing or future services based on the status of the
          matter and the work completed.
        </p>
        <p>
          Once completed drafts or finalized documents have been
          delivered, services are considered earned and non-refundable.
        </p>
        <p>
          I understand that unexpected situations can arise, and
          reasonable requests related to unforeseen circumstances will
          always be considered with care on a case-by-case basis.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Identical pattern to hourly-mediation.astro for visual consistency ---- */
  .svc-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/documents2.jpeg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .svc-header::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .svc-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .svc-header .kicker { color: var(--color-gold); text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9); }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-gold); font-weight: 600; transition: color 0.2s; }
  .back-link:hover { color: var(--color-cream); }
  .arrow-left { transition: transform 0.3s var(--ease-out); }
  .back-link:hover .arrow-left { transform: translateX(-3px); }
  .kicker-sep { color: color-mix(in srgb, var(--color-cream) 30%, transparent); margin-inline: 0.4rem; }
  .svc-title { margin-top: 1rem; font-size: var(--step-5); line-height: 1.02; color: var(--color-cream); letter-spacing: -0.025em; max-width: 22ch; font-weight: 400; text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9); }
  .svc-title .display-italic { color: var(--color-gold); font-weight: 400; }
  .svc-header .lede { margin-top: 1.5rem; max-width: 60ch; color: color-mix(in srgb, var(--color-cream) 85%, transparent); text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9); }
  .svc-header-cta { margin-top: 0; }
  .svc-header-ctas {
    margin-top: 1.75rem;
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .svc-header-cta-pay {
    background: var(--color-navy);
    color: var(--color-cream);
    border: 1px solid var(--color-gold);
  }
  .svc-header-cta-pay:hover {
    background: var(--color-navy-deep);
    color: var(--color-cream);
    border-color: var(--color-gold);
    transform: translateY(-1px);
  }
  .svc-header-cta-pay .arrow { transition: transform 0.4s var(--ease-out); }
  .svc-header-cta-pay:hover .arrow { transform: translateX(4px); }

  .svc-facts { padding-block: var(--space-xl); background: var(--color-cream); border-bottom: 1px solid var(--color-divider); }
  .facts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem 2rem; margin: 0; }
  .fact { display: flex; flex-direction: column; gap: 0.35rem; }
  .fact-label { font-size: 0.7rem; color: var(--color-gold-deep); font-weight: 700; letter-spacing: 0.24em; }
  .fact-value { margin: 0; font-size: 1.15rem; color: var(--color-navy); font-variation-settings: "opsz" 24; line-height: 1.2; }
  .facts-note { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-divider); font-family: var(--font-body); font-size: 0.92rem; line-height: 1.6; color: var(--color-ink-soft); max-width: 70ch; font-style: italic; }
  .facts-note strong { color: var(--color-navy); font-weight: 600; font-style: normal; }
  .facts-note a { font-style: normal; }

  .svc-section { padding-block: var(--space-2xl); }
  .svc-section-alt { background: var(--color-cream-warm); }
  .svc-prose { font-family: var(--font-body); font-size: var(--step-1); line-height: 1.7; color: var(--color-ink-soft); max-width: 60ch; }
  .svc-prose p + p { margin-top: 1.25rem; }
  .svc-prose strong { color: var(--color-navy); font-weight: 500; }

  .cta { position: relative; padding-block: var(--space-3xl); background: var(--color-cream); color: var(--color-ink); overflow: hidden; border-top: 1px solid var(--color-divider); }
  .cta::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 1px; background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent); opacity: 0.7; }
  .cta-kicker { color: var(--color-gold-deep); }
  .cta-title { margin-block: 1rem 1.5rem; font-size: var(--step-4); line-height: 1.05; letter-spacing: -0.02em; color: var(--color-navy); max-width: 22ch; }
  .cta-title .display-italic { color: var(--color-gold-deep); }
  .cta-lede { color: var(--color-ink-soft); max-width: 56ch; }
  .cta-actions { margin-top: 2rem; display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
  .cta-btn { background: var(--color-navy); color: var(--color-cream); border-color: var(--color-navy); }
  .cta-btn:hover { background: var(--color-navy-deep); color: var(--color-cream); border-color: var(--color-gold); }
  .cta-link { color: var(--color-navy); background-image: linear-gradient(var(--color-gold), var(--color-gold)); }
  .cta-link:hover { color: var(--color-gold-deep); }

  /* ============================================================
     REFUND POLICY
     ============================================================ */
  .refund {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-divider);
    position: relative;
  }
  .refund::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.55;
  }
  .refund-kicker {
    font-size: 1.05rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.22em;
    margin-bottom: 1rem;
    display: block;
  }
  .refund-title {
    font-size: var(--step-3);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }
  .refund-body {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 62ch;
  }
  .refund-body p + p { margin-top: 1.25rem; }

  @media (max-width: 720px) {
    .facts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .facts-grid { grid-template-columns: 1fr; }
  }
</style>
