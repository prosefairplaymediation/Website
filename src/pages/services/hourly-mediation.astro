---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GoldService from "../../components/GoldService.astro";

const facts = [
  { label: "Rate", value: "$600 / hour" },
  { label: "Minimum", value: "Two hours" },
  { label: "Format", value: "Zoom · Confidential" },
  { label: "Sessions", value: "Half-day, full-day, same-day" },
];

---

<BaseLayout
  title="Hourly Mediation · Pro Se Fair Play Mediation"
  description="Family-law mediation for self-represented parties in Florida. $600 per hour combined rate, two-hour minimum. Conducted via Zoom in a structured, confidential environment."
>
  <!-- ========================== HEADER ========================== -->
  <header class="svc-header">
    <div class="container svc-header-inner">
      <h1 class="display svc-title reveal reveal-d2">
        Hourly <span class="display-italic">Mediation</span><span class="display-italic">.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        A neutral, guided conversation where both parties work toward a
        mutually acceptable resolution — without a judge imposing a
        decision. Conducted via Zoom, structured, confidential.
      </p>
      <a class="btn btn-primary svc-header-cta reveal reveal-d4" href="/book">
        Book a Free Consultation
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </header>

  <!-- ========================== AT-A-GLANCE ========================== -->
  <section class="svc-facts">
    <div class="container">
      <dl class="facts-grid">
        {facts.map((f) => (
          <div class="fact">
            <dt class="fact-label smallcaps">{f.label}</dt>
            <dd class="fact-value display">{f.value}</dd>
          </div>
        ))}
      </dl>
      <p class="facts-note">
        $600 hourly rate is a <strong>combined rate</strong>, commonly split
        evenly between the two parties (e.g., $300 each per hour). One party
        may also pay in full.
      </p>
    </div>
  </section>

  <!-- ========================== PROSE ========================== -->
  <section class="svc-section svc-section-alt">
    <div class="container-narrow">
      <div class="svc-prose">
        <p>
          I provide professional family mediation services designed to
          help families navigate difficult transitions in a structured,
          respectful, and supportive environment. My goal is to help
          parties work toward practical and meaningful resolutions
          outside of the courtroom whenever possible while reducing
          unnecessary conflict, emotional stress, and financial strain
          on the family. I am also a Notary Public, and any documents
          from the mediation process that require notarization are
          included at no additional cost.
        </p>
        <p>
          As a neutral mediator, my role is to facilitate productive
          communication, keep discussions focused and organized, and
          help both parties navigate sensitive conversations with
          professionalism. I understand that no two families are alike,
          and every situation deserves thoughtful attention.
        </p>
        <p>
          Mediation gives parents the opportunity to remain in control
          of the decisions that will impact their lives and the
          well-being of their children, rather than placing those
          important decisions entirely in the hands of the court.
          Through a calm and structured process, families are able to
          work toward solutions that reflect their unique needs,
          priorities, and long-term goals while creating a healthier
          path forward for everyone involved.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================== GOLD SERVICE ========================== -->
  <GoldService />

  <!-- ========================== CTA ========================== -->
  <section class="cta">
    <div class="container-narrow cta-inner">
      <p class="kicker cta-kicker">Ready to talk?</p>
      <h2 class="display cta-title">
        Start with a <span class="display-italic">free</span> 15-minute consultation.
      </h2>
      <p class="lede cta-lede">
        I'd like to discuss your case and determine whether mediation is
        the right fit. The consultation is free, with no commitment.
      </p>
      <div class="cta-actions">
        <a class="btn btn-primary cta-btn" href="/book">
          Book a Free Consultation
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================== CANCELLATION + REFUND POLICY ========================== -->
  <section class="refund">
    <div class="container-narrow">
      <p class="refund-kicker">Mediation</p>
      <h2 class="display refund-title">Refund Policy</h2>
      <div class="refund-body">
        <p>
          At Pro Se Fair Play Mediation LLC, mediation sessions involve
          reserved professional time, scheduling coordination between
          parties, and advance preparation to ensure a productive and
          structured process. I understand that life happens and strive
          to maintain a policy that is both fair to clients and
          respectful of the time reserved for each matter.
        </p>

        <h3 class="refund-subhead">Cancellations &amp; Rescheduling</h3>
        <p>
          Cancellations or rescheduling requests made more than
          twenty-four (24) hours prior to a scheduled session are
          eligible for either:
        </p>
        <ul class="refund-list">
          <li>a full refund to the original payment method, or</li>
          <li>a full session credit to be applied toward a future mediation session.</li>
        </ul>
        <p>
          For cancellations made less than twenty-four (24) hours
          before the scheduled session, fifty percent (50%) of the
          mediation retainer will be retained as a reserved session
          and preparation fee. The remaining balance may be applied
          as a one-time credit toward a rescheduled session scheduled
          within thirty (30) days, subject to availability.
        </p>
        <p>
          Clients who fail to appear for a scheduled mediation session
          without notice will forfeit the full mediation retainer.
        </p>

        <h3 class="refund-subhead">Courtesy Rescheduling</h3>
        <p>
          One courtesy reschedule may be accommodated for unforeseen
          circumstances, provided reasonable notice is given and
          scheduling availability permits.
        </p>

        <h3 class="refund-subhead">Emergency Circumstances</h3>
        <p>
          Emergency situations and unforeseen events may be considered
          on a case-by-case basis at the sole discretion of Pro Se
          Fair Play Mediation LLC.
        </p>

        <h3 class="refund-subhead">Refund Processing</h3>
        <p>
          Approved refunds will be processed to the original payment
          method. Processing times may vary depending on the financial
          institution or payment provider.
        </p>

        <h3 class="refund-subhead">Reserved Professional Time</h3>
        <p>
          By scheduling a mediation session, clients acknowledge that
          mediation appointments involve reserved professional time
          and preparation that cannot typically be reassigned on short
          notice. This policy is intended to maintain fairness,
          scheduling integrity, and availability for all parties.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     HEADER
     ============================================================ */
  .svc-header {
    position: relative;
    padding-block: clamp(5rem, 7vw + 2rem, 8rem) clamp(3rem, 4vw + 1rem, 5rem);
    color: var(--color-cream);
    background-color: var(--color-navy-deep);
    background-image:
      linear-gradient(135deg,
        rgba(15, 27, 50, 0.78) 0%,
        rgba(27, 42, 74, 0.62) 50%,
        rgba(27, 42, 74, 0.78) 100%),
      url('/handshake4.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .svc-header::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-cream));
    pointer-events: none;
  }
  .svc-header-inner { position: relative; max-width: 64rem; z-index: 1; }
  .svc-header .kicker {
    color: var(--color-gold);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-gold);
    font-weight: 600;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-cream); }
  .arrow-left { transition: transform 0.3s var(--ease-out); }
  .back-link:hover .arrow-left { transform: translateX(-3px); }
  .kicker-sep { color: color-mix(in srgb, var(--color-cream) 30%, transparent); margin-inline: 0.4rem; }
  .svc-title {
    margin-top: 1rem;
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-cream);
    letter-spacing: -0.025em;
    max-width: 22ch;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .svc-title .display-italic {
    color: var(--color-gold);
    font-weight: 400;
  }
  .svc-header .lede {
    margin-top: 1.5rem;
    max-width: 60ch;
    color: color-mix(in srgb, var(--color-cream) 85%, transparent);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.9);
  }
  .svc-header-cta {
    margin-top: 1.75rem;
  }

  /* ============================================================
     AT-A-GLANCE FACTS
     ============================================================ */
  .svc-facts {
    padding-block: var(--space-xl);
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
  }
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem 2rem;
    margin: 0;
  }
  .fact { display: flex; flex-direction: column; gap: 0.35rem; }
  .fact-label {
    font-size: 1.00rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
  }
  .fact-value {
    margin: 0;
    font-size: 1.15rem;
    color: var(--color-navy);
    font-variation-settings: "opsz" 24;
    line-height: 1.2;
  }
  .facts-note {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-divider);
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    max-width: 70ch;
    font-style: italic;
  }
  .facts-note strong { color: var(--color-navy); font-weight: 600; font-style: normal; }

  /* ============================================================
     SECTIONS
     ============================================================ */
  .svc-section {
    padding-block: var(--space-2xl);
  }
  .svc-section-alt {
    background: var(--color-cream-warm);
  }
  .svc-prose {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }
  .svc-prose p + p { margin-top: 1.25rem; }
  .svc-prose strong { color: var(--color-navy); font-weight: 500; }

  /* ============================================================
     CTA
     ============================================================ */
  .cta {
    position: relative;
    padding-block: var(--space-3xl);
    background: var(--color-cream-warm);
    color: var(--color-ink);
    overflow: hidden;
    border-top: 1px solid var(--color-divider);
  }
  .cta::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.7;
  }
  .cta-kicker { color: var(--color-gold-deep); font-size: 0.97rem; }
  .cta-title {
    margin-block: 1rem 1.5rem;
    font-size: var(--step-4);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-navy);
    max-width: 22ch;
  }
  .cta-title .display-italic { color: var(--color-gold-deep); }
  .cta-lede {
    color: var(--color-ink-soft);
    max-width: 56ch;
  }
  .cta-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    background: var(--color-navy);
    color: var(--color-cream);
    border-color: var(--color-navy);
  }
  .cta-btn:hover {
    background: var(--color-navy-deep);
    color: var(--color-cream);
    border-color: var(--color-gold);
  }
  .cta-link {
    color: var(--color-navy);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
  }
  .cta-link:hover { color: var(--color-gold-deep); }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  /* ============================================================
     CANCELLATION + REFUND POLICY
     ============================================================ */
  .refund {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream);
    border-top: 1px solid var(--color-divider);
    position: relative;
  }
  .refund::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.55;
  }
  .refund-kicker {
    font-size: 0.97rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }
  .refund-title {
    font-size: var(--step-4);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }
  .refund-body {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 62ch;
  }
  .refund-body p + p { margin-top: 1.25rem; }
  .refund-subhead {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 1.3rem;
    line-height: 1.25;
    color: var(--color-navy);
    letter-spacing: -0.005em;
    font-weight: 500;
  }
  .refund-list {
    margin: 0.75rem 0 1.25rem;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .refund-list li { line-height: 1.55; }

  @media (max-width: 720px) {
    .facts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .facts-grid { grid-template-columns: 1fr; }
  }
</style>
