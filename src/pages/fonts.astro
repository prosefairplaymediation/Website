---
import BaseLayout from "../layouts/BaseLayout.astro";

const options = [
  {
    id: "source-serif",
    name: "Source Serif 4",
    family: `"Source Serif 4", "Iowan Old Style", Georgia, serif`,
    descriptor: "Clean classical. Current choice.",
    note: "Variable optical sizing, balanced proportions, neutral personality — modern but timeless. Works at every size.",
  },
  {
    id: "cormorant",
    name: "Cormorant Garamond",
    family: `"Cormorant Garamond", "Iowan Old Style", Georgia, serif`,
    descriptor: "Delicate elegance. A modern Garamond.",
    note: "Refined, graceful letterforms with traditional roots. Slightly aristocratic — feels like a wedding invitation or high-end magazine.",
  },
  {
    id: "bodoni",
    name: "Bodoni Moda",
    family: `"Bodoni Moda", "Iowan Old Style", Georgia, serif`,
    descriptor: "Editorial formality. High contrast, dramatic serifs.",
    note: "Neoclassical with extreme thick-thin contrast. Projects authority and gravitas — feels like a formal legal journal or fashion editorial.",
  },
  {
    id: "lora",
    name: "Lora",
    family: `"Lora", "Iowan Old Style", Georgia, serif`,
    descriptor: "Warm humanist. Approachable but credible.",
    note: "Softer, friendlier letterforms while still reading as professional. Leans accessible and modern — less formal, more welcoming.",
  },
];
---

<BaseLayout
  title="Font Preview · Pro Se Fair Play Mediation"
  description="Typography comparison — previewing display fonts for the site."
>
  <!-- ========================== INTRO ========================== -->
  <section class="preview-intro">
    <div class="container preview-intro-inner">
      <p class="kicker">
        <span class="kicker-dot" aria-hidden="true"></span>
        Font Preview
      </p>
      <h1 class="display preview-title">
        Pick a typeface.
      </h1>
      <p class="lede">
        Four display fonts, same editorial-legal vein, meaningfully different
        personalities. Each is shown below using the actual homepage hero
        copy so you can see it doing real work. Scroll through, note which
        one feels most like <em>you</em>, and tell me.
      </p>
      <p class="preview-note">
        Body copy will stay the same across all choices — the differences you
        see are in the display font (headings, the slogan, and large serif
        moments).
      </p>
    </div>
  </section>

  <!-- ========================== VARIANTS ========================== -->
  {options.map((opt, i) => (
    <section class={`variant ${i % 2 === 1 ? "variant-alt" : ""}`} data-font={opt.id}>
      <div class="container variant-inner">
        <header class="variant-head">
          <p class="variant-num display">{String(i + 1).padStart(2, "0")}</p>
          <div class="variant-name-block">
            <h2 class="variant-name display">{opt.name}</h2>
            <p class="variant-descriptor">{opt.descriptor}</p>
          </div>
          <p class="variant-note">{opt.note}</p>
        </header>

        <hr class="rule variant-divider" />

        <div class="variant-sample" style={`--font-display: ${opt.family};`}>
          <p class="sample-kicker">
            <span class="kicker-dot" aria-hidden="true"></span>
            Florida Family Law · Mediation · Document Preparation
          </p>

          <h3 class="sample-title display">
            <span class="sample-line">Where We</span>
            <span class="sample-line">
              <span class="sample-level">Level</span>
            </span>
            <span class="sample-line">The Playing Field.</span>
          </h3>

          <p class="sample-lede">
            We help self-represented parties in Florida navigate family law
            matters — mediation, parenting plans, and court-ready documents —
            conducted in accordance with the standards set by the Florida
            Supreme Court.
          </p>

          <p class="sample-foot">
            Google Meet · Confidential · Flat-fee where possible
          </p>
        </div>
      </div>
    </section>
  ))}

  <!-- ========================== CLOSE ========================== -->
  <section class="preview-close">
    <div class="container-narrow">
      <p class="eyebrow-numeral">§</p>
      <p class="kicker">Decision</p>
      <h2 class="display preview-close-title">
        Which one feels like <span class="display-italic">you</span>?
      </h2>
      <p class="lede preview-close-lede">
        There's no wrong answer. Each of these would be beautiful. Pick the
        one whose personality lines up with how you want people to feel when
        they land on your site — before they've read a word.
      </p>
      <p class="preview-close-tip">
        Not sure? Try reading each sample out loud. The one that sounds like
        <em>your</em> voice is usually the right pick.
      </p>
      <a class="link-underline" href="/">
        <span class="arrow" aria-hidden="true">←</span>
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     INTRO
     ============================================================ */
  .preview-intro {
    position: relative;
    padding-block: clamp(4rem, 6vw + 1rem, 6.5rem) clamp(2.5rem, 4vw, 4rem);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
    overflow: hidden;
  }
  .preview-intro::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(27, 45, 90, 0.03) 1px, transparent 1px);
    background-size: 7rem 100%;
    mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    pointer-events: none;
  }
  .preview-intro-inner { position: relative; max-width: 58rem; }
  .preview-title {
    font-size: var(--step-5);
    line-height: 1;
    color: var(--color-navy);
    margin-top: 1rem;
    letter-spacing: -0.025em;
    font-weight: 400;
  }
  .preview-intro .lede {
    margin-top: 1.25rem;
    max-width: 54ch;
  }
  .preview-note {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--color-slate);
    font-style: italic;
    max-width: 54ch;
  }

  /* ============================================================
     VARIANT
     ============================================================ */
  .variant {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-divider);
  }
  .variant-alt { background: var(--color-cream-warm); }

  .variant-head {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: baseline;
  }
  .variant-num {
    font-size: var(--step-3);
    color: var(--color-gold);
    letter-spacing: -0.01em;
    line-height: 1;
    font-variation-settings: "opsz" 48;
  }
  .variant-name {
    font-size: var(--step-2);
    color: var(--color-navy);
    letter-spacing: -0.01em;
    line-height: 1.05;
    font-weight: 400;
  }
  .variant-descriptor {
    margin-top: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-slate);
  }
  .variant-note {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .variant-divider {
    margin-block: 2rem 2.5rem;
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-gold) 12%, var(--color-divider) 12%, var(--color-divider) 100%);
  }

  /* The actual font sample — mimics the hero */
  .variant-sample {
    max-width: 54rem;
  }
  .sample-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
  }
  .kicker-dot {
    width: 6px; height: 6px;
    background: var(--color-gold);
    border-radius: 50%;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-gold) 18%, transparent);
  }

  .sample-title {
    margin-top: 1.5rem;
    font-size: clamp(2.5rem, 1.8rem + 3.4vw, 5rem);
    line-height: 0.94;
    color: var(--color-navy);
    letter-spacing: -0.025em;
    font-weight: 400;
  }
  .sample-line {
    display: block;
    white-space: nowrap;
  }
  .sample-level {
    position: relative;
    display: inline-block;
  }
  .sample-level::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0.1em;
    width: calc(100% + clamp(3rem, 6vw, 6rem));
    height: 2px;
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-gold) 78%, transparent 100%);
  }

  .sample-lede {
    margin-top: 1.75rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--color-ink-soft);
    max-width: 46ch;
  }

  .sample-foot {
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-slate);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.08em;
  }

  /* ============================================================
     CLOSE
     ============================================================ */
  .preview-close {
    padding-block: var(--space-3xl);
    background: var(--color-navy-deep);
    color: var(--color-cream);
    position: relative;
    overflow: hidden;
  }
  .preview-close::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.55;
  }
  .preview-close .eyebrow-numeral {
    color: var(--color-gold);
    font-size: var(--step-3);
    display: block;
    margin-bottom: 0.5rem;
  }
  .preview-close .kicker { color: var(--color-gold); }
  .preview-close-title {
    margin-block: 1rem 1.5rem;
    font-size: var(--step-4);
    color: var(--color-cream);
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 22ch;
  }
  .preview-close-lede {
    color: color-mix(in srgb, var(--color-cream) 78%, var(--color-navy));
    max-width: 58ch;
  }
  .preview-close-tip {
    margin-top: 1.25rem;
    color: color-mix(in srgb, var(--color-cream) 55%, var(--color-navy));
    font-size: 0.95rem;
    font-style: italic;
    max-width: 58ch;
  }
  .preview-close .link-underline {
    margin-top: 2rem;
    display: inline-flex;
    color: var(--color-cream);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
  }
  .preview-close .link-underline:hover { color: var(--color-gold); }
  .preview-close .link-underline .arrow { margin-right: 0.25rem; }

  @media (max-width: 820px) {
    .variant-head {
      grid-template-columns: auto 1fr;
    }
    .variant-note {
      grid-column: 1 / -1;
      margin-top: 0.5rem;
    }
  }
</style>
