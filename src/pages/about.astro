---
import BaseLayout from "../layouts/BaseLayout.astro";

const credentials = [
  { label: "Training", value: "Certified Florida Supreme Court Family Law Mediator" },
  { label: "Jurisdiction", value: "State of Florida" },
  { label: "Practice", value: "Family Law · Pro Se Parties" },
  { label: "Format", value: "Zoom, Confidential" },
];
---

<BaseLayout
  title="About Marie · Pro Se Fair Play Mediation"
  description="Marie VanGinHoven is a Certified Florida Supreme Court Family Law Mediator who helps self-represented individuals navigate family law with clarity, structure, and care."
>
  <!-- ========================== PROFILE HEADER ========================== -->
  <header class="profile-header">
    <div class="container profile-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        About Me
      </p>
      <h1 class="display profile-name reveal reveal-d2">
        Marie <span class="display-italic">VanGinHoven</span>
      </h1>
      <p class="profile-tagline display display-italic reveal reveal-d3">
        A process you can trust. A space where you feel safe.
      </p>
    </div>
  </header>

  <!-- ========================== PROFILE BODY ========================== -->
  <section class="profile-body">
    <div class="container profile-grid">
      <figure class="profile-figure reveal reveal-d2">
        <div class="profile-figure-frame">
          <img
            src="/professional.jpeg"
            alt="Portrait of Marie VanGinHoven"
            width="900" height="1350"
            loading="eager"
            fetchpriority="high"
            class="profile-img"
          />
          <div class="profile-figure-corners" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
        <figcaption class="profile-caption">
          <span class="profile-caption-line" aria-hidden="true"></span>
          <span class="smallcaps">Marie VanGinHoven</span>
          <span class="profile-caption-sub">Founder &amp; Mediator</span>
        </figcaption>

        <dl class="profile-credentials">
          {credentials.map((c) => (
            <div class="cred">
              <dt class="cred-label smallcaps">{c.label}</dt>
              <dd class="cred-value">{c.value}</dd>
            </div>
          ))}
        </dl>
      </figure>

      <article class="profile-article reveal reveal-d3">
        <p class="profile-eyebrow smallcaps">A note from Marie</p>

        <p class="profile-p">
          I created this practice with one goal in mind: to give people a
          better way to move through difficult situations without feeling
          overwhelmed, unheard, or out of control. Because that's what
          most people experience when dealing with legal matters:
          confusion, pressure, stress, and decisions being made for them
          instead of by them. That's not how this process should feel.
        </p>

        <h2 class="profile-h2 display">My Background</h2>
        <p class="profile-p">
          I bring a strong foundation in legal operations, litigation
          support, and case management as a Florida Supreme Court Family Law
          Mediator. This means your process is not only structured and
          organized, but also aligned with the standards and expectations
          of the court system.
        </p>
        <p class="profile-p">
          You're not just getting guidance — you're getting a process
          that is thoughtful, organized, and professionally grounded.
        </p>

        <h2 class="profile-h2 display">My Approach</h2>
        <p class="profile-p">
          When you work with me, my role is simple: I guide the process,
          you stay in control. I create a structured, calm environment
          where you can speak openly, feel heard and respected, and
          understand what's happening at every step. Nothing is rushed.
          Nothing is forced. Every decision remains yours.
        </p>

        <h2 class="profile-h2 display">What You Can Expect</h2>
        <p class="profile-p">
          Clients come to me because they want something different — a
          process that feels safe, not stressful; clear, not confusing;
          balanced, not one-sided. Whether your situation is
          straightforward or high-conflict, I keep things grounded,
          focused, and moving forward.
        </p>

        <h2 class="profile-h2 display">Why This Matters</h2>
        <p class="profile-p">
          The decisions being made aren't just legal — they're personal.
          They affect your family, your time, and your future. You
          deserve to be part of that process in a real and meaningful
          way, with the confidence that it's being handled correctly.
        </p>

        <blockquote class="profile-pullquote">
          <p class="display display-italic">
            This is your process. Your family. Your decisions.
          </p>
          <cite class="profile-pullquote-cite">— Marie</cite>
        </blockquote>

        <p class="profile-p">
          I'm here to guide you through it with clarity, structure, and care.
        </p>

        <div class="profile-ctas">
          <a class="btn btn-primary" href="/book">
            Book a Free 15-Minute Consultation
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </article>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     PROFILE HEADER
     ============================================================ */
  .profile-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 2rem, 7rem) clamp(2rem, 3vw, 3.5rem);
    background:
      radial-gradient(ellipse at 20% 30%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    overflow: hidden;
  }
  .profile-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(27, 45, 90, 0.035) 1px, transparent 1px);
    background-size: 7rem 100%;
    mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    pointer-events: none;
  }
  .profile-header-inner { position: relative; }
  .profile-name {
    font-size: var(--step-6);
    line-height: 0.96;
    color: var(--color-navy);
    letter-spacing: -0.03em;
    margin-top: 1rem;
    max-width: 18ch;
    font-weight: 400;
  }
  .profile-name .display-italic {
    color: var(--color-gold-deep);
    font-weight: 300;
  }
  .profile-tagline {
    margin-top: 1.5rem;
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--color-navy);
    max-width: 32ch;
    font-weight: 400;
  }

  /* ============================================================
     PROFILE BODY — magazine layout
     ============================================================ */
  .profile-body {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: minmax(0, 22rem) minmax(0, 1fr);
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* Figure */
  .profile-figure {
    position: sticky;
    top: 5.5rem;
    margin: 0;
  }
  .profile-figure-frame {
    position: relative;
    padding: 0.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }
  .profile-figure-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 0%, transparent 45%, rgba(196, 154, 75, 0.05) 100%);
    pointer-events: none;
  }
  .profile-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2/3;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.92) contrast(1.02);
    transition: filter 0.6s var(--ease-out);
  }
  .profile-figure:hover .profile-img {
    filter: saturate(1) contrast(1.02);
  }
  /* Corner ticks like a contact-sheet frame */
  .profile-figure-corners span {
    position: absolute;
    width: 14px; height: 14px;
    border-color: var(--color-gold);
    border-style: solid;
    border-width: 0;
  }
  .profile-figure-corners span:nth-child(1) { top: 0; left: 0; border-top-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(2) { top: 0; right: 0; border-top-width: 1px; border-right-width: 1px; }
  .profile-figure-corners span:nth-child(3) { bottom: 0; left: 0; border-bottom-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(4) { bottom: 0; right: 0; border-bottom-width: 1px; border-right-width: 1px; }

  .profile-caption {
    margin-top: 1.25rem;
    color: var(--color-slate);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    position: relative;
  }
  .profile-caption-line {
    position: absolute;
    top: 0; left: 0;
    width: 2.5rem; height: 1px;
    background: var(--color-gold);
  }
  .profile-caption .smallcaps {
    color: var(--color-navy);
    font-size: 2.16rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    line-height: 1.1;
  }
  .profile-caption-sub {
    font-family: var(--font-display);
    font-style: italic;
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 1.84rem;
    line-height: 1.2;
    color: var(--color-gold-deep);
  }

  /* Article */
  .profile-article {
    max-width: 60ch;
  }
  .profile-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.24em;
    color: var(--color-gold-deep);
    font-weight: 700;
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-divider);
    display: block;
    position: relative;
  }
  .profile-eyebrow::after {
    content: "";
    position: absolute;
    bottom: -1px; left: 0;
    width: 2.5rem; height: 1px;
    background: var(--color-gold);
  }
  .profile-p {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.66;
    color: var(--color-ink-soft);
  }
  .profile-p + .profile-p { margin-top: 1.25rem; }

  .profile-pullquote {
    margin-block: 2.5rem;
    padding: 1.5rem 0 1.5rem 1.75rem;
    border-left: 2px solid var(--color-gold);
    max-width: 46ch;
  }
  .profile-pullquote p {
    font-size: var(--step-3);
    line-height: 1.2;
    color: var(--color-navy);
    font-weight: 400;
  }
  .profile-pullquote-cite {
    display: block;
    margin-top: 0.85rem;
    font-size: 0.85rem;
    font-style: normal;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-slate);
  }

  .profile-h2 {
    margin-block: 2rem 1.25rem;
    font-size: var(--step-3);
    color: var(--color-navy);
    line-height: 1.1;
    letter-spacing: -0.015em;
    max-width: 22ch;
  }

  /* Credentials — sits in the figure column under the photo caption */
  .profile-credentials {
    margin-top: 1.75rem;
    padding: 1.25rem 1.25rem 1.35rem;
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid var(--color-divider);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  .cred {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.2rem;
  }
  .cred-label {
    font-size: 0.66rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
  }
  .cred-value {
    margin: 0;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 1.02rem;
    line-height: 1.3;
    color: var(--color-navy);
  }

  .profile-ctas {
    margin-top: var(--space-xl);
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 900px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-figure { position: static; max-width: 26rem; margin-inline: auto; }
  }

  @media (max-width: 600px) {
    /* Long single words ("VanGinHoven", and oversized headings) overflow
       the viewport on phones at the default font-sizes. Tighten everything. */
    .profile-name {
      font-size: clamp(2.5rem, 1.6rem + 4vw, 4rem);
      max-width: 100%;
    }
    .profile-tagline {
      font-size: clamp(1.1rem, 0.9rem + 1.2vw, 1.5rem);
    }
    .profile-caption .smallcaps {
      font-size: clamp(1.4rem, 1.1rem + 2.8vw, 2.16rem);
      letter-spacing: 0.08em;
    }
    .profile-caption-sub {
      font-size: clamp(1.25rem, 1rem + 2.4vw, 1.84rem);
    }
    .profile-h2 {
      font-size: clamp(1.5rem, 1.2rem + 2vw, 2.25rem);
    }
    .profile-pullquote p {
      font-size: clamp(1.5rem, 1.2rem + 2vw, 2rem);
    }
    .profile-pullquote {
      padding-left: 1.25rem;
      max-width: 100%;
    }
    /* Safety net: any display heading wraps gracefully if needed */
    .display {
      overflow-wrap: break-word;
    }
  }
</style>
