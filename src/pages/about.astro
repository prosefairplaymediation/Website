---
import BaseLayout from "../layouts/BaseLayout.astro";

const credentials = [
  { label: "Training", value: "Florida Supreme Court Certified Family Mediator" },
  { label: "Practice", value: "Family Law · Pro Se Parties" },
  { label: "Format", value: "Zoom, Confidential" },
];
---

<BaseLayout
  title="About Marie · Pro Se Fair Play Mediation"
  description="Marie VanGinHoven, Florida Supreme Court Certified Family Mediator and founder of Pro Se Fair Play Mediation LLC, helps self-represented (pro se) parties prepare court-ready family law documents and navigate mediation."
>
  <!-- ========================== PROFILE HEADER ========================== -->
  <header class="profile-header">
    <div class="container profile-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        About Me
      </p>
      <h1 class="display profile-name reveal reveal-d2">
        Marie <span class="display-italic">VanGinHoven</span>
      </h1>
      <p class="profile-tagline display display-italic reveal reveal-d3">
        A process you can trust. A space where you feel safe.
      </p>
    </div>
  </header>

  <!-- ========================== PROFILE BODY ========================== -->
  <section class="profile-body">
    <div class="container profile-grid">
      <figure class="profile-figure reveal reveal-d2">
        <div class="profile-figure-frame">
          <img
            src="/professional.jpeg"
            alt="Portrait of Marie VanGinHoven"
            width="900" height="1350"
            loading="eager"
            fetchpriority="high"
            class="profile-img"
          />
          <div class="profile-figure-corners" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
        <figcaption class="profile-caption">
          <span class="profile-caption-line" aria-hidden="true"></span>
          <span class="smallcaps">Marie VanGinHoven</span>
          <span class="profile-caption-sub">Founder &amp; Mediator</span>
        </figcaption>

        <dl class="profile-credentials">
          {credentials.map((c) => (
            <div class="cred">
              <dt class="cred-label smallcaps">{c.label}</dt>
              <dd class="cred-value">{c.value}</dd>
            </div>
          ))}
        </dl>
      </figure>

      <article class="profile-article reveal reveal-d3">
        <p class="profile-p">
          I am a Florida Supreme Court Certified Family Mediator and
          the founder of Pro Se Fair Play Mediation LLC, a practice
          focused exclusively on family law matters.
        </p>

        <p class="profile-p">
          My practice is centered around two core services: professional
          family mediation and court-ready family law document
          preparation for self-represented individuals. I work with
          clients seeking a more structured, efficient, and
          cost-conscious approach to navigating the family court
          process while maintaining professionalism, organization, and
          attention to detail throughout the process.
        </p>

        <p class="profile-p">
          What sets my practice apart is a focused approach dedicated
          exclusively to family law matters and the unique needs of
          individuals navigating the court system without full
          knowledge of the court system. Family court can often feel
          overwhelming, emotionally exhausting, and procedurally
          complex: especially for parents trying to protect their
          children while also understanding the legal process.
        </p>

        <p class="profile-p">
          My passion for this work is deeply personal. Having
          experienced a child custody matter firsthand, I understand
          the emotional weight these cases carry and the importance of
          creating stability, structure, and clarity for families
          during difficult transitions. That experience helped shape
          the foundation of my practice and continues to drive my
          commitment to helping parents navigate the process with
          professionalism, organization, and care.
        </p>

        <p class="profile-p">
          At the center of every matter is the well-being of the
          children involved. My goal is to help families move forward
          with clear communication, properly prepared documents, and
          structured solutions designed to support healthier
          co-parenting relationships and long-term family stability.
        </p>

        <div class="profile-ctas">
          <a class="btn btn-primary" href="/book">
            Book a Free 15-Minute Consultation
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </article>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     PROFILE HEADER
     ============================================================ */
  .profile-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 2rem, 7rem) clamp(2rem, 3vw, 3.5rem);
    background:
      radial-gradient(ellipse at 20% 30%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    overflow: hidden;
  }
  .profile-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(27, 45, 90, 0.035) 1px, transparent 1px);
    background-size: 7rem 100%;
    mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    pointer-events: none;
  }
  .profile-header-inner { position: relative; }
  .profile-name {
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-navy);
    letter-spacing: -0.025em;
    margin-top: 1rem;
    max-width: 18ch;
    font-weight: 400;
  }
  .profile-name .display-italic {
    color: var(--color-gold-deep);
    font-weight: 300;
  }
  .profile-tagline {
    margin-top: 1.5rem;
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--color-navy);
    max-width: 32ch;
    font-weight: 400;
  }

  /* ============================================================
     PROFILE BODY — magazine layout
     ============================================================ */
  .profile-body {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: minmax(0, 22rem) minmax(0, 1fr);
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* Figure */
  .profile-figure {
    position: sticky;
    top: 5.5rem;
    margin: 0;
  }
  .profile-figure-frame {
    position: relative;
    padding: 0.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }
  .profile-figure-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 0%, transparent 45%, rgba(196, 154, 75, 0.05) 100%);
    pointer-events: none;
  }
  .profile-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2/3;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.92) contrast(1.02);
    transition: filter 0.6s var(--ease-out);
  }
  .profile-figure:hover .profile-img {
    filter: saturate(1) contrast(1.02);
  }
  /* Corner ticks like a contact-sheet frame */
  .profile-figure-corners span {
    position: absolute;
    width: 14px; height: 14px;
    border-color: var(--color-gold);
    border-style: solid;
    border-width: 0;
  }
  .profile-figure-corners span:nth-child(1) { top: 0; left: 0; border-top-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(2) { top: 0; right: 0; border-top-width: 1px; border-right-width: 1px; }
  .profile-figure-corners span:nth-child(3) { bottom: 0; left: 0; border-bottom-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(4) { bottom: 0; right: 0; border-bottom-width: 1px; border-right-width: 1px; }

  .profile-caption {
    margin-top: 1.25rem;
    color: var(--color-slate);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    position: relative;
  }
  .profile-caption-line {
    position: absolute;
    top: 0; left: 0;
    width: 2.5rem; height: 1px;
    background: var(--color-gold);
  }
  .profile-caption .smallcaps {
    color: var(--color-navy);
    font-size: 2.16rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    line-height: 1.1;
  }
  .profile-caption-sub {
    font-family: var(--font-display);
    font-style: italic;
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 1.84rem;
    line-height: 1.2;
    color: var(--color-gold-deep);
  }

  /* Article */
  .profile-article {
    max-width: 60ch;
  }
  .profile-p {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.66;
    color: var(--color-ink-soft);
  }
  .profile-p + .profile-p { margin-top: 1.25rem; }
  .profile-p em {
    font-style: italic;
    font-family: var(--font-display);
  }

  /* Credentials — sits in the figure column under the photo caption */
  .profile-credentials {
    margin-top: 1.75rem;
    padding: 1.25rem 1.25rem 1.35rem;
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid var(--color-divider);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  .cred {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.2rem;
  }
  .cred-label {
    font-size: 0.66rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
  }
  .cred-value {
    margin: 0;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 1.02rem;
    line-height: 1.3;
    color: var(--color-navy);
  }

  .profile-ctas {
    margin-top: var(--space-xl);
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 900px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-figure { position: static; max-width: 26rem; margin-inline: auto; }
  }

  @media (max-width: 600px) {
    /* Long single words ("VanGinHoven", and oversized headings) overflow
       the viewport on phones at the default font-sizes. Tighten everything. */
    .profile-name {
      font-size: clamp(2.5rem, 1.6rem + 4vw, 4rem);
      max-width: 100%;
    }
    .profile-tagline {
      font-size: clamp(1.1rem, 0.9rem + 1.2vw, 1.5rem);
    }
    .profile-caption .smallcaps {
      font-size: clamp(1.4rem, 1.1rem + 2.8vw, 2.16rem);
      letter-spacing: 0.08em;
    }
    .profile-caption-sub {
      font-size: clamp(1.25rem, 1rem + 2.4vw, 1.84rem);
    }
    /* Safety net: any display heading wraps gracefully if needed */
    .display {
      overflow-wrap: break-word;
    }
  }
</style>
