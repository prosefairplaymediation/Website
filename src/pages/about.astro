---
import BaseLayout from "../layouts/BaseLayout.astro";

const credentials = [
  { label: "Training", value: "Florida Supreme Court–trained Mediator" },
  { label: "Jurisdiction", value: "State of Florida" },
  { label: "Practice", value: "Family Law · Pro Se Parties" },
  { label: "Format", value: "Zoom-based, Confidential" },
];
---

<BaseLayout
  title="About Marie · Pro Se Fair Play Mediation"
  description="Marie VanGinHoven is a Florida Supreme Court–trained mediator who helps self-represented individuals navigate family law with clarity, structure, and confidence."
>
  <!-- ========================== PROFILE HEADER ========================== -->
  <header class="profile-header">
    <div class="container profile-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        About · The Mediator
      </p>
      <h1 class="display profile-name reveal reveal-d2">
        Marie <span class="display-italic">VanGinHoven</span>
      </h1>
      <p class="profile-title reveal reveal-d3">
        <span class="profile-title-rule" aria-hidden="true"></span>
        Florida Supreme Court–trained Mediator
      </p>
    </div>
  </header>

  <!-- ========================== PROFILE BODY ========================== -->
  <section class="profile-body">
    <div class="container profile-grid">
      <figure class="profile-figure reveal reveal-d2">
        <div class="profile-figure-frame">
          <img
            src="/professional.jpeg"
            alt="Portrait of Marie VanGinHoven"
            width="900" height="1350"
            loading="eager"
            fetchpriority="high"
            class="profile-img"
          />
          <div class="profile-figure-corners" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
        <figcaption class="profile-caption">
          <span class="profile-caption-line" aria-hidden="true"></span>
          <span class="smallcaps">Marie VanGinHoven</span>
          <span class="profile-caption-sub">Founder &amp; Mediator</span>
        </figcaption>
      </figure>

      <article class="profile-article reveal reveal-d3">
        <p class="profile-eyebrow smallcaps">A note from Marie</p>

        <p class="profile-p profile-p--opener dropcap">
          I'm Marie, a Florida Supreme Court–trained mediator dedicated to
          helping individuals navigate difficult legal situations with
          clarity, structure, and confidence.
        </p>

        <p class="profile-p">
          Having personally experienced the challenges of navigating the court
          system without representation, I understand how overwhelming and
          isolating the process can feel. That experience is what drives my
          passion for helping others find practical, fair, and efficient
          resolutions — without unnecessary conflict or confusion.
        </p>

        <p class="profile-p">
          My approach is calm, neutral, and solutions-focused. I provide a
          professional space where both parties can be heard, explore
          options, and work toward mutually acceptable outcomes.
        </p>

        <blockquote class="profile-pullquote">
          <p class="display display-italic">
            You don't have to go through this alone.
          </p>
          <cite class="profile-pullquote-cite">— Marie</cite>
        </blockquote>

        <h2 class="profile-h2 display">What that looks like, in practice.</h2>

        <p class="profile-p">
          Most of the people I work with arrive stressed, uncertain, and
          holding more questions than answers. My role is not to argue your
          case — I can't, and wouldn't — but to make the process legible:
          what needs to happen, what can be negotiated, what the paperwork
          actually means, and how to walk into a final hearing prepared.
        </p>
        <p class="profile-p">
          I am not an attorney. I do not give legal advice or represent either
          party. What I do is quieter and, for many self-represented parties,
          more useful: I prepare documents to be filing-ready, I keep difficult
          conversations on track, and I help both sides leave the table with
          a workable agreement where one is possible.
        </p>

        <!-- Credentials strip -->
        <dl class="profile-credentials">
          {credentials.map((c) => (
            <div class="cred">
              <dt class="cred-label smallcaps">{c.label}</dt>
              <dd class="cred-value">{c.value}</dd>
            </div>
          ))}
        </dl>

        <div class="profile-ctas">
          <a class="btn btn-primary" href="/book">
            Book a Free 15-Minute Consultation
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a class="link-underline" href="/services">
            See services &amp; pricing
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- ========================== WHAT IS MEDIATION ========================== -->
  <section class="mediation-explainer">
    <div class="container explainer-grid">
      <div class="explainer-head">
        <p class="eyebrow-numeral">§</p>
        <p class="kicker explainer-kicker">The Solution</p>
        <h2 class="display explainer-title">
          What is <span class="display-italic">mediation?</span>
        </h2>
      </div>

      <div class="explainer-body">
        <p class="explainer-lede lede">
          Mediation is a confidential, structured process where a neutral
          third party helps individuals resolve disputes outside of court.
          Rather than a judge making decisions for you, mediation lets
          both parties communicate, negotiate, and reach agreements together.
        </p>

        <div class="proSe-block">
          <p class="kicker proSe-kicker">
            <span class="kicker-dot" aria-hidden="true"></span>
            Mediation for Pro Se Parties
          </p>
          <p class="proSe-intro">
            For individuals representing themselves, mediation offers a
            powerful alternative to navigating complex legal procedures alone.
            It provides:
          </p>

          <ul class="proSe-list">
            <li>
              <span class="proSe-num display">01</span>
              <p>A <strong>guided process</strong> — without the pressure of courtroom litigation.</p>
            </li>
            <li>
              <span class="proSe-num display">02</span>
              <p>A <strong>neutral environment</strong> to discuss issues openly.</p>
            </li>
            <li>
              <span class="proSe-num display">03</span>
              <p>The ability to reach <strong>agreements that reflect your real-life needs</strong> — not just legal outcomes.</p>
            </li>
          </ul>

          <p class="proSe-close">
            While I do not provide legal advice or representation, I help
            facilitate productive conversations and keep the process focused,
            respectful, and solution-oriented.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================== ETHICS STRIP ========================== -->
  <section class="ethics-strip">
    <div class="container-narrow ethics-inner">
      <p class="eyebrow-numeral">§</p>
      <p class="kicker ethics-kicker">The line I don't cross</p>
      <p class="ethics-copy">
        I am <strong>not a lawyer</strong>, and I don't pretend otherwise.
        I do not represent either party, create an attorney-client
        relationship, file documents with the court on your behalf, or
        appear in court on your behalf. Every client is encouraged to
        consult a licensed attorney for legal advice specific to their
        situation.
      </p>
      <p class="ethics-copy ethics-foot">
        All mediation services are conducted in accordance with the Florida
        Supreme Court Rules for Certified and Court-Appointed Mediators and
        Chapter 44 Florida Statutes.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     PROFILE HEADER
     ============================================================ */
  .profile-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 2rem, 7rem) clamp(2rem, 3vw, 3.5rem);
    background:
      radial-gradient(ellipse at 20% 30%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    overflow: hidden;
  }
  .profile-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(27, 45, 90, 0.035) 1px, transparent 1px);
    background-size: 7rem 100%;
    mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 75%, transparent 100%);
    pointer-events: none;
  }
  .profile-header-inner { position: relative; }
  .profile-name {
    font-size: var(--step-6);
    line-height: 0.96;
    color: var(--color-navy);
    letter-spacing: -0.03em;
    margin-top: 1rem;
    max-width: 18ch;
    font-weight: 400;
  }
  .profile-name .display-italic {
    color: var(--color-gold-deep);
    font-weight: 300;
  }
  .profile-title {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-slate);
  }
  .profile-title-rule {
    display: inline-block;
    width: 2.5rem; height: 1px;
    background: var(--color-gold);
  }

  /* ============================================================
     PROFILE BODY — magazine layout
     ============================================================ */
  .profile-body {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--color-cream);
  }
  .profile-grid {
    display: grid;
    grid-template-columns: minmax(0, 22rem) minmax(0, 1fr);
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* Figure */
  .profile-figure {
    position: sticky;
    top: 5.5rem;
    margin: 0;
  }
  .profile-figure-frame {
    position: relative;
    padding: 0.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
  }
  .profile-figure-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, transparent 0%, transparent 45%, rgba(196, 154, 75, 0.05) 100%);
    pointer-events: none;
  }
  .profile-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2/3;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.92) contrast(1.02);
    transition: filter 0.6s var(--ease-out);
  }
  .profile-figure:hover .profile-img {
    filter: saturate(1) contrast(1.02);
  }
  /* Corner ticks like a contact-sheet frame */
  .profile-figure-corners span {
    position: absolute;
    width: 14px; height: 14px;
    border-color: var(--color-gold);
    border-style: solid;
    border-width: 0;
  }
  .profile-figure-corners span:nth-child(1) { top: 0; left: 0; border-top-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(2) { top: 0; right: 0; border-top-width: 1px; border-right-width: 1px; }
  .profile-figure-corners span:nth-child(3) { bottom: 0; left: 0; border-bottom-width: 1px; border-left-width: 1px; }
  .profile-figure-corners span:nth-child(4) { bottom: 0; right: 0; border-bottom-width: 1px; border-right-width: 1px; }

  .profile-caption {
    margin-top: 1rem;
    font-size: 0.82rem;
    letter-spacing: 0.22em;
    color: var(--color-slate);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.85rem;
    position: relative;
  }
  .profile-caption-line {
    position: absolute;
    top: 0; left: 0;
    width: 2.25rem; height: 1px;
    background: var(--color-gold);
  }
  .profile-caption .smallcaps {
    color: var(--color-navy);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .profile-caption-sub {
    font-style: italic;
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 0.78rem;
    color: var(--color-slate);
  }

  /* Article */
  .profile-article {
    max-width: 60ch;
  }
  .profile-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.24em;
    color: var(--color-gold-deep);
    font-weight: 700;
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-divider);
    display: block;
    position: relative;
  }
  .profile-eyebrow::after {
    content: "";
    position: absolute;
    bottom: -1px; left: 0;
    width: 2.5rem; height: 1px;
    background: var(--color-gold);
  }
  .profile-p {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.66;
    color: var(--color-ink-soft);
  }
  .profile-p + .profile-p { margin-top: 1.25rem; }
  .profile-p--opener { font-size: calc(var(--step-1) * 1.08); }

  .profile-pullquote {
    margin-block: 2.5rem;
    padding: 1.5rem 0 1.5rem 1.75rem;
    border-left: 2px solid var(--color-gold);
    max-width: 46ch;
  }
  .profile-pullquote p {
    font-size: var(--step-3);
    line-height: 1.2;
    color: var(--color-navy);
    font-weight: 400;
  }
  .profile-pullquote-cite {
    display: block;
    margin-top: 0.85rem;
    font-size: 0.85rem;
    font-style: normal;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-slate);
  }

  .profile-h2 {
    margin-block: 2rem 1.25rem;
    font-size: var(--step-3);
    color: var(--color-navy);
    line-height: 1.1;
    letter-spacing: -0.015em;
    max-width: 22ch;
  }

  /* Credentials */
  .profile-credentials {
    margin-top: var(--space-xl);
    padding: 1.5rem;
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid var(--color-divider);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 2rem;
  }
  .cred { display: flex; flex-direction: column; gap: 0.15rem; }
  .cred-label {
    font-size: 0.68rem;
    color: var(--color-gold-deep);
    font-weight: 700;
    letter-spacing: 0.24em;
  }
  .cred-value {
    margin: 0;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 1rem;
    color: var(--color-navy);
  }

  .profile-ctas {
    margin-top: var(--space-xl);
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ============================================================
     WHAT IS MEDIATION — explainer
     ============================================================ */
  .mediation-explainer {
    padding-block: var(--space-3xl);
    background: var(--color-cream-warm);
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
    position: relative;
  }
  .mediation-explainer::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 35%, var(--color-gold) 65%, transparent);
    opacity: 0.55;
  }
  .explainer-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }
  .explainer-head {
    position: sticky;
    top: 5.5rem;
  }
  .explainer-head .eyebrow-numeral {
    display: block;
    color: var(--color-gold);
    font-size: var(--step-4);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .explainer-kicker { margin-bottom: 0.85rem; }
  .explainer-title {
    font-size: var(--step-4);
    line-height: 1.02;
    color: var(--color-navy);
    letter-spacing: -0.02em;
    max-width: 12ch;
  }

  .explainer-body {
    max-width: 62ch;
  }
  .explainer-lede {
    font-size: var(--step-1);
    line-height: 1.65;
    color: var(--color-ink-soft);
  }

  .proSe-block {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-divider);
    position: relative;
  }
  .proSe-block::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 3rem; height: 1px;
    background: var(--color-gold);
  }
  .proSe-kicker {
    margin-bottom: 0.85rem;
  }
  .proSe-intro {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  .proSe-list {
    list-style: none;
    padding: 0;
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .proSe-list li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 1rem 1.25rem;
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
    position: relative;
  }
  .proSe-list li::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 1.5rem; height: 1px;
    background: var(--color-gold);
  }
  .proSe-num {
    font-size: 1.35rem;
    color: var(--color-gold-deep);
    font-weight: 400;
    font-variation-settings: "opsz" 48;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .proSe-list p {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .proSe-list strong {
    color: var(--color-navy);
    font-weight: 500;
  }

  .proSe-close {
    margin-top: 1.75rem;
    padding: 1.25rem 1.5rem;
    border-left: 2px solid var(--color-gold);
    background: color-mix(in srgb, var(--color-cream) 65%, transparent);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  /* ============================================================
     ETHICS STRIP
     ============================================================ */
  .ethics-strip {
    background: var(--color-cream-warm);
    color: var(--color-ink);
    padding-block: var(--space-2xl);
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--color-divider);
  }
  .ethics-strip::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold) 40%, var(--color-gold) 60%, transparent);
    opacity: 0.7;
  }
  .ethics-inner {
    position: relative;
    text-align: left;
  }
  .ethics-strip .eyebrow-numeral {
    color: var(--color-gold-deep);
    font-size: var(--step-3);
    display: block;
    margin-bottom: 0.5rem;
  }
  .ethics-kicker { color: var(--color-gold-deep); }
  .ethics-copy {
    margin-top: 1.25rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-ink-soft);
    max-width: 66ch;
  }
  .ethics-copy strong {
    color: var(--color-navy);
    font-weight: 600;
  }
  .ethics-foot {
    margin-top: 1.5rem;
    font-size: 0.88rem;
    font-style: italic;
    color: var(--color-slate);
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 900px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-figure { position: static; max-width: 26rem; margin-inline: auto; }
    .profile-credentials { grid-template-columns: 1fr; }
    .explainer-grid { grid-template-columns: 1fr; }
    .explainer-head { position: static; }
  }

  @media (max-width: 600px) {
    /* Long single words ("VanGinHoven", and oversized headings) overflow
       the viewport on phones at the default font-sizes. Tighten everything. */
    .profile-name {
      font-size: clamp(2.5rem, 1.6rem + 4vw, 4rem);
      max-width: 100%;
    }
    .profile-h2 {
      font-size: clamp(1.5rem, 1.2rem + 2vw, 2.25rem);
    }
    .explainer-title {
      font-size: clamp(1.75rem, 1.4rem + 2vw, 2.5rem);
    }
    .profile-pullquote p {
      font-size: clamp(1.5rem, 1.2rem + 2vw, 2rem);
    }
    .profile-pullquote {
      padding-left: 1.25rem;
      max-width: 100%;
    }
    /* Safety net: any display heading wraps gracefully if needed */
    .display {
      overflow-wrap: break-word;
    }
  }
</style>
