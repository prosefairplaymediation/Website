---
import BaseLayout from "../layouts/BaseLayout.astro";
import PayCard from "../components/PayCard.astro";

// Stripe Payment Links (Stripe Dashboard > Payment Links). Each mediation
// link redirects (Stripe side) to the matching /thank-you-*-hour scheduling
// page; the 1-hour VIP link redirects to /thank-you-one-hour; document-service
// links redirect to /thank-you. Mediation is a linear $600/hour combined rate
// (1h $600 → 8h $4,800); VIP is a flat $650.
const med1hFullUrl = "https://buy.stripe.com/28EeVcfuk9GEbcVg7y3sI03";
const med1hSplitUrl = "https://buy.stripe.com/cNi4gybe4bOMep7bRi3sI04";
const med2hFullUrl = "https://buy.stripe.com/dRm14m1DubOMcgZ8F63sI05";
const med2hSplitUrl = "https://buy.stripe.com/9B69ASfukf0Y2Gp7B23sI06";
const med4hFullUrl = "https://buy.stripe.com/aFafZgbe48CAa8R1cE3sI07";
const med4hSplitUrl = "https://buy.stripe.com/aFaeVceqgaKIgxf9Ja3sI08";
const med8hFullUrl = "https://buy.stripe.com/bJe3cufukdWUftb3kM3sI09";
const med8hSplitUrl = "https://buy.stripe.com/5kQ28qfukf0Ydl32gI3sI0a";
const med1hVipUrl = "https://buy.stripe.com/8x29ASdmcaKI3Kt6wY3sI0b";

const parentingPlanUrl = "https://buy.stripe.com/4gM28q4PG3ig5SBdZq3sI01";
const courtPacketUrl = "https://buy.stripe.com/5kQfZg1DucSQ0yh6wY3sI00";

const mediationDetail = "/services/hourly-mediation";

// Each duration shows its Full (one payer) and Split (per party) cards.
const mediationGroups = [
  {
    duration: "One Hour",
    cards: [
      {
        slug: "mediation_1h_full",
        title: "Full Rate",
        context: "One-Hour Mediation, full rate",
        price: "$600",
        value: 600,
        description:
          "The full combined rate for a one-hour mediation session, charged to a single payer — not split between the parties.",
        payUrl: med1hFullUrl,
      },
      {
        slug: "mediation_1h_split",
        title: "Split Rate",
        context: "One-Hour Mediation, split rate",
        price: "$300 / party",
        value: 300,
        description:
          "One party's half of a one-hour mediation session. Use this when the two parties split the cost evenly; each pays their share separately.",
        payUrl: med1hSplitUrl,
      },
    ],
  },
  {
    duration: "Two Hours",
    cards: [
      {
        slug: "mediation_2h_full",
        title: "Full Rate",
        context: "Two-Hour Mediation, full rate",
        price: "$1,200",
        value: 1200,
        description:
          "The full combined rate for a two-hour mediation session, charged to a single payer — not split between the parties.",
        payUrl: med2hFullUrl,
      },
      {
        slug: "mediation_2h_split",
        title: "Split Rate",
        context: "Two-Hour Mediation, split rate",
        price: "$600 / party",
        value: 600,
        description:
          "One party's half of a two-hour mediation session. Use this when the two parties split the cost evenly; each pays their share separately.",
        payUrl: med2hSplitUrl,
      },
    ],
  },
  {
    duration: "Half Day",
    cards: [
      {
        slug: "mediation_4h_full",
        title: "Full Rate",
        context: "Four-Hour Mediation, full rate",
        price: "$2,400",
        value: 2400,
        description:
          "The full combined rate for a four-hour mediation session, charged to a single payer — not split between the parties.",
        payUrl: med4hFullUrl,
      },
      {
        slug: "mediation_4h_split",
        title: "Split Rate",
        context: "Four-Hour Mediation, split rate",
        price: "$1,200 / party",
        value: 1200,
        description:
          "One party's half of a four-hour mediation session. Use this when the two parties split the cost evenly; each pays their share separately.",
        payUrl: med4hSplitUrl,
      },
    ],
  },
  {
    duration: "Full Day",
    cards: [
      {
        slug: "mediation_8h_full",
        title: "Full Rate",
        context: "Eight-Hour Mediation, full rate",
        price: "$4,800",
        value: 4800,
        description:
          "The full combined rate for an eight-hour mediation session, charged to a single payer — not split between the parties.",
        payUrl: med8hFullUrl,
      },
      {
        slug: "mediation_8h_split",
        title: "Split Rate",
        context: "Eight-Hour Mediation, split rate",
        price: "$2,400 / party",
        value: 2400,
        description:
          "One party's half of an eight-hour mediation session. Use this when the two parties split the cost evenly; each pays their share separately.",
        payUrl: med8hSplitUrl,
      },
    ],
  },
];

const documentProducts = [
  {
    slug: "parenting_plan",
    title: "Parenting Plan Preparation",
    price: "$400 flat",
    value: 400,
    description:
      "A customized Parenting Plan tailored to your family's schedule, structure, and needs. Court-ready format, drafted from the information you provide.",
    detail: "/services/parenting-plan",
    payUrl: parentingPlanUrl,
  },
  {
    slug: "court_packet",
    title: "Turn-Key Court Packet",
    price: "$600 flat",
    value: 600,
    description:
      "A complete, organized set of family-law documents — Parenting Plan, required Florida Supreme Court forms, and notarization where applicable — assembled into a filing-ready packet.",
    detail: "/services/court-packet",
    payUrl: courtPacketUrl,
  },
];
---

<BaseLayout
  title="Pay for a Service · Pro Se Fair Play Mediation"
  description="Pay online for mediation (hourly, half-day, or full-day), Parenting Plan Preparation, or the Turn-Key Court Packet. Secure payment processed by Stripe."
>
  <!-- ========================== HEADER ========================== -->
  <header class="pay-header">
    <div class="container pay-header-inner">
      <p class="kicker reveal reveal-d1">
        <span class="kicker-dot" aria-hidden="true"></span>
        Secure Payment
      </p>
      <h1 class="display pay-title reveal reveal-d2">
        Service <span class="display-italic">payment portal</span><span class="display-italic">.</span>
      </h1>
      <p class="lede reveal reveal-d3">
        For clients who have already discussed their case and agreed on
        the scope of work. Select your service below to pay securely
        through Stripe. Payment is processed on Stripe's hosted
        checkout; no card details are stored on this site.
      </p>
    </div>
  </header>

  <!-- ========================== BODY ========================== -->
  <section class="pay-body">
    <div class="container-narrow">
      <form
        id="pay-form"
        class="pay-agreement"
        onsubmit="event.preventDefault();"
        novalidate
      >
        <label class="pay-checkbox">
          <input type="checkbox" id="pay-agree" />
          <span class="pay-checkbox-mark" aria-hidden="true"></span>
          <span class="pay-checkbox-text">
            I have read and agree to the{" "}
            <a class="link-underline" href="/pay/agreement" target="_blank" rel="noopener">
              Engagement Agreement
            </a>.
          </span>
        </label>
      </form>

      <!-- ========================== MEDIATION ========================== -->
      <div class="pay-section">
        <h2 class="pay-section-title display">Mediation</h2>
        {mediationGroups.map((group) => (
          <div class="pay-group">
            <h3 class="pay-group-title">{group.duration}</h3>
            <ul class="pay-products" role="list">
              {group.cards.map((c) => (
                <PayCard
                  title={c.title}
                  context={c.context}
                  price={c.price}
                  description={c.description}
                  detail={mediationDetail}
                  payUrl={c.payUrl}
                  slug={c.slug}
                  value={c.value}
                  headingLevel="h4"
                />
              ))}
            </ul>
          </div>
        ))}

        <div class="pay-group">
          <h3 class="pay-group-title">Gold Service</h3>
          <ul class="pay-products pay-products--single" role="list">
            <PayCard
              title="One-Hour"
              context="One-Hour Gold Service Mediation"
              price="$650"
              description="A one-hour Gold Service mediation session, charged to a single payer."
              detail={mediationDetail}
              payUrl={med1hVipUrl}
              slug="mediation_1h_vip"
              value={650}
              headingLevel="h4"
            />
          </ul>
        </div>
      </div>

      <!-- ========================== DOCUMENT SERVICES ========================== -->
      <div class="pay-section">
        <h2 class="pay-section-title display">Document Services</h2>
        <ul class="pay-products" role="list">
          {documentProducts.map((p) => (
            <PayCard
              title={p.title}
              price={p.price}
              description={p.description}
              detail={p.detail}
              payUrl={p.payUrl}
              slug={p.slug}
              value={p.value}
              headingLevel="h3"
            />
          ))}
        </ul>
      </div>

      <p class="pay-foot">
        Need to talk first? <a class="link-underline" href="/book">Book a free 15-minute consultation</a>.
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const checkbox = document.getElementById("pay-agree");
      const buttons = document.querySelectorAll("[data-pay-btn]");
      if (!checkbox || buttons.length === 0) return;

      function sync() {
        const enabled = checkbox.checked;
        buttons.forEach(function (btn) {
          if (enabled) {
            btn.setAttribute("aria-disabled", "false");
            btn.removeAttribute("tabindex");
          } else {
            btn.setAttribute("aria-disabled", "true");
            btn.setAttribute("tabindex", "-1");
          }
        });
      }

      checkbox.addEventListener("change", sync);

      // The browser restores the checkbox state on back/forward navigation
      // (e.g. returning from Stripe), but no "change" event fires for that
      // restore — so the buttons would stay in their disabled markup default
      // while the box shows checked. Re-sync on pageshow, which fires on
      // initial load, bfcache restores, and back-navigation alike.
      window.addEventListener("pageshow", sync);

      // Anchor tags can't be truly disabled — block clicks while the
      // checkbox is unchecked. When enabled, fire a GA4 event before
      // the browser navigates away to Stripe so we can measure how
      // often each product's Pay Now button is actually used.
      buttons.forEach(function (btn) {
        btn.addEventListener("click", function (e) {
          if (btn.getAttribute("aria-disabled") === "true") {
            e.preventDefault();
            checkbox.focus();
            return;
          }
          if (typeof window.gtag === "function") {
            window.gtag("event", "pay_checkout_click", {
              product: btn.dataset.product || "unknown",
              value: Number(btn.dataset.value) || 0,
              currency: "USD",
            });
          }
        });
      });

      sync();
    })();
  </script>
</BaseLayout>

<style>
  /* ============================================================
     HEADER
     ============================================================ */
  .pay-header {
    position: relative;
    padding-block: clamp(4rem, 6vw + 1rem, 6rem) clamp(2rem, 3vw, 3rem);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(196, 154, 75, 0.08), transparent 55%),
      var(--color-cream);
    border-bottom: 1px solid var(--color-divider);
    overflow: hidden;
  }
  .pay-header-inner { position: relative; max-width: 64rem; }
  .pay-title {
    font-size: var(--step-5);
    line-height: 1.02;
    color: var(--color-navy);
    margin-top: 1rem;
    letter-spacing: -0.025em;
    max-width: 22ch;
    font-weight: 400;
  }
  .pay-title .display-italic {
    color: var(--color-gold-deep);
    font-weight: 400;
  }
  .pay-header .lede {
    margin-top: 1.5rem;
    max-width: 60ch;
    color: var(--color-ink-soft);
  }

  /* ============================================================
     BODY
     ============================================================ */
  .pay-body {
    padding-block: var(--space-xl) var(--space-3xl);
    background: var(--color-cream);
  }

  /* ============================================================
     AGREEMENT CHECKBOX
     ============================================================ */
  .pay-agreement {
    background: var(--color-paper);
    border: 1px solid var(--color-divider);
    border-left: 3px solid var(--color-gold);
    padding: 1.25rem 1.5rem;
    margin-bottom: var(--space-lg);
  }
  .pay-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .pay-checkbox input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }
  .pay-checkbox-mark {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 2px;
    border: 1.5px solid var(--color-gold);
    border-radius: 3px;
    background: var(--color-cream);
    position: relative;
    transition: background 0.2s, border-color 0.2s;
  }
  .pay-checkbox-mark::after {
    content: "";
    position: absolute;
    top: 3px; left: 7px;
    width: 5px; height: 10px;
    border: solid var(--color-cream);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .pay-checkbox input:checked ~ .pay-checkbox-mark {
    background: var(--color-gold-deep);
    border-color: var(--color-gold-deep);
  }
  .pay-checkbox input:checked ~ .pay-checkbox-mark::after {
    opacity: 1;
  }
  .pay-checkbox input:focus-visible ~ .pay-checkbox-mark {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
  .pay-checkbox-text strong { color: var(--color-navy); }

  /* ============================================================
     SECTIONS & DURATION GROUPS
     ============================================================ */
  .pay-section + .pay-section {
    margin-top: var(--space-2xl);
  }
  .pay-section-title {
    font-size: var(--step-3);
    line-height: 1.1;
    color: var(--color-navy);
    letter-spacing: -0.015em;
    font-weight: 400;
    margin-bottom: var(--space-lg);
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-gold);
  }
  /* Divider + spacing between successive duration groups. */
  .pay-group + .pay-group {
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-divider);
  }
  .pay-group-title {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
    margin-bottom: 1rem;
  }

  /* ============================================================
     PRODUCT GRID (cards themselves live in PayCard.astro)
     ============================================================ */
  .pay-products {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  /* A section with a single card (VIP) — hold it to one column's width so
     it matches the paired cards above instead of stretching the full row. */
  .pay-products--single {
    grid-template-columns: 1fr;
  }
  @media (min-width: 721px) {
    .pay-products--single {
      max-width: calc((100% - clamp(1.25rem, 3vw, 2rem)) / 2);
    }
  }

  /* ============================================================
     FOOT
     ============================================================ */
  .pay-foot {
    margin-top: var(--space-xl);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-ink-soft);
    text-align: center;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 720px) {
    .pay-products {
      grid-template-columns: 1fr;
    }
  }
</style>
