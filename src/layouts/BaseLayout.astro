---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Pro Se Fair Play Mediation, LLC",
  description = "Mediation and document preparation for self-represented individuals. I help you walk into court informed, prepared, and never alone.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NH6HKR18MZ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NH6HKR18MZ');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1B2D5A" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#1B2D5A" />
    <link rel="apple-touch-icon" href="/scales_icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pro Se Fair Play" />

    <!-- Open Graph / link-preview tags (iMessage, Slack, Facebook, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pro Se Fair Play Mediation, LLC" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:image" content={new URL("/logo_BG_color_Cropped.png", Astro.site).href} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/logo_BG_color_Cropped.png", Astro.site).href} />

    <!-- Schema.org structured data for the business. Using
         ProfessionalService rather than LegalService to stay
         consistent with the site's "not a law firm" disclaimer. -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Pro Se Fair Play Mediation, LLC",
      "alternateName": "Pro Se Fair Play Mediation",
      "url": "https://prosefairplaymediation.com",
      "description": "Florida Supreme Court Certified Family Mediator providing professional family mediation and court-ready family law document preparation for self-represented (pro se) individuals.",
      "email": "info@prosefairplaymediation.com",
      "telephone": "+1-866-883-6777",
      "image": "https://prosefairplaymediation.com/logo_BG_color_Cropped.png",
      "logo": "https://prosefairplaymediation.com/logo_BG_color_Cropped.png",
      "founder": {
        "@type": "Person",
        "name": "Marie VanGinHoven",
        "jobTitle": "Florida Supreme Court Certified Family Mediator"
      },
      "areaServed": {
        "@type": "State",
        "name": "Florida"
      },
      "serviceType": [
        "Family Mediation",
        "Parenting Plan Preparation",
        "Family Law Document Preparation"
      ],
      "knowsAbout": [
        "Family Law Mediation",
        "Parenting Plans",
        "Florida Supreme Court Family Law Forms",
        "Self-Represented Litigation Support",
        "Pro Se Document Preparation"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "url": "https://prosefairplaymediation.com/services/hourly-mediation",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "600.00",
              "priceCurrency": "USD",
              "unitText": "HUR"
            },
            "itemOffered": {
              "@type": "Service",
              "name": "Hourly Family Mediation",
              "description": "Neutral, structured family mediation conducted via Zoom. Two-hour minimum."
            }
          },
          {
            "@type": "Offer",
            "url": "https://prosefairplaymediation.com/services/parenting-plan",
            "price": "600.00",
            "priceCurrency": "USD",
            "itemOffered": {
              "@type": "Service",
              "name": "Parenting Plan Preparation",
              "description": "Customized Parenting Plan tailored to your family, delivered in a clear, court-ready format."
            }
          },
          {
            "@type": "Offer",
            "url": "https://prosefairplaymediation.com/services/court-packet",
            "price": "800.00",
            "priceCurrency": "USD",
            "itemOffered": {
              "@type": "Service",
              "name": "Turn-Key Court Packet",
              "description": "Complete family law document package, professionally organized and assembled into a filing-ready packet with notarization where applicable."
            }
          }
        ]
      },
      "sameAs": []
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Newsreader:ital,opsz,wght@0,6..72,300..700;1,6..72,300..700&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/*
      Floating bottom-left slogan — disabled in favor of an in-nav slogan.
      Kept here (and styles in global.css) for potential future re-enable.

      <aside class="floating-slogan" aria-hidden="true">
        <span class="floating-slogan-text">Where we level the playing field.</span>
      </aside>

      <script is:inline>
        (function () {
          const slogan = document.querySelector(".floating-slogan");
          const footerMotto = document.querySelector(".footer-motto");
          if (!slogan || !footerMotto) return;

          requestAnimationFrame(() => {
            requestAnimationFrame(() => slogan.classList.add("is-visible"));
          });

          const obs = new IntersectionObserver(
            (entries) => {
              const entry = entries[0];
              slogan.classList.toggle("is-docked", entry.isIntersecting);
            },
            { rootMargin: "0px 0px -20px 0px", threshold: 0 }
          );
          obs.observe(footerMotto);
        })();
      </script>
    */}
  </body>
</html>
